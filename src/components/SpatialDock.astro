---
/**
 * SpatialDock — Replaces the traditional top‑bar with a floating
 * bottom dock anchored in 3D space. Each item has a haptic‑style
 * hover micro‑animation, a tooltip, and active‑section highlighting.
 */
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="spatial-dock" id="spatial-dock" aria-label="Main navigation">
  <!-- Logo / Home -->
  <a href="/" class="dock-item dock-logo" data-label="Home" aria-label="Home">
    <img src="/logo.png" alt="" width="22" height="22" class="dock-logo-img logo-dark" />
    <img src="/logo_light.png" alt="" width="22" height="22" class="dock-logo-img logo-light" />
  </a>

  <span class="dock-divider"></span>

  <a href="/#about-me" class="dock-item" data-label="About Me" data-section="about-me">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
  </a>

  <a href="/#services" class="dock-item" data-label="Services" data-section="services">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
  </a>

  <a href="/#works" class="dock-item" data-label="Works" data-section="works">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
  </a>

  <a href="/#contact" class="dock-item" data-label="Contact" data-section="contact">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
  </a>

  <span class="dock-divider"></span>

  <ThemeToggle />

  <a href="/cv.pdf" target="_blank" rel="noopener noreferrer" class="dock-item dock-cta" data-label="Download CV">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
  </a>
</nav>

<script>
  /* ── Active-section highlighting ── */
  const dockItems = document.querySelectorAll<HTMLAnchorElement>('.dock-item[data-section]');
  const sections = new Map<string, Element>();

  dockItems.forEach((item) => {
    const sectionId = item.dataset.section;
    if (sectionId) {
      const el = document.getElementById(sectionId) || document.querySelector(`.${sectionId}`);
      if (el) sections.set(sectionId, el);
    }
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const id = entry.target.id || entry.target.classList[0];
        const link = document.querySelector<HTMLAnchorElement>(`.dock-item[data-section="${id}"]`);
        if (link) {
          entry.isIntersecting ? link.classList.add('active') : link.classList.remove('active');
        }
      });
    },
    { threshold: 0.2 }
  );

  sections.forEach((el) => observer.observe(el));

  /* ── Show/hide dock on scroll ── */
  const dock = document.getElementById('spatial-dock');
  let lastY = 0;
  window.addEventListener('scroll', () => {
    if (!dock) return;
    const y = window.scrollY;
    if (y < 100) {
      dock.style.opacity = '0';
      dock.style.transform = 'translateX(-50%) translateY(20px)';
    } else {
      dock.style.opacity = '1';
      dock.style.transform = 'translateX(-50%) translateY(0)';
    }
    lastY = y;
  }, { passive: true });

  /* ── Micro-animation: scale-bounce on click ── */
  dockItems.forEach((item) => {
    item.addEventListener('click', () => {
      item.style.transform = 'translateY(-6px) scale(0.85)';
      setTimeout(() => { item.style.transform = ''; }, 200);
    });
  });

  /* ── Initial state ── */
  if (dock && window.scrollY < 100) {
    dock.style.opacity = '0';
    dock.style.transform = 'translateX(-50%) translateY(20px)';
  }
</script>

<style>
  /* CTA item special accent */
  .dock-cta {
    color: var(--color-orange) !important;
    opacity: 0.8;
  }
  .dock-cta:hover {
    opacity: 1;
    background: var(--color-orange-dim) !important;
  }
  .dock-logo-img {
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  .logo-dark { display: block; }
  .logo-light { display: none; }
  :global([data-theme="light"]) .logo-dark { display: none; }
  :global([data-theme="light"]) .logo-light { display: block; }
</style>
