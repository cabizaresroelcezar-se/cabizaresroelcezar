---
interface Props {
  image: string;
  title: string;
  description: string;
  link?: string;
}

const { image, title, description, link = '#' } = Astro.props;
---

<article class="work-article" data-aos="fade-up">
  <img src={image} alt={title} class="work-image" loading="lazy" width="504" height="400" />
  <div class="work-text">
    <h3 class="mb-4 leading-[1.3]">{title}</h3>
    <p class="text-section font-light text-gray-400 leading-relaxed mb-4">{description}</p>
    <a href={link} class="text-white font-medium uppercase letter-spacing-[1px] hover:text-gray-300 transition">
      Explore →
    </a>
  </div>
</article>

<style>
  .work-article {
    display: flex;
    padding: 5% 0;
    gap: 5%;
    align-items: flex-start;
  }

  .work-image {
    width: 100%;
    max-width: 504px;
    filter: grayscale(1);
    transition: filter 0.4s ease;
    flex-shrink: 0;
  }

  .work-article:hover .work-image {
    filter: grayscale(0);
  }

  .work-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .work-text h3 {
    font-size: 2.3rem;
    font-weight: 400;
    line-height: 1.3;
    color: #f8f8f8;
  }

  @media only screen and (max-width: 768px) {
    .work-article {
      flex-direction: column;
      gap: 1.5rem;
    }

    .work-image {
      max-width: 100%;
    }

    .work-text h3 {
      font-size: 1.5rem;
    }
  }
</style>
