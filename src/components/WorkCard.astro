---
interface Props {
  image: string;
  title: string;
  description: string;
  tags?: string[];
  link?: string;
}

const { image, title, description, tags = [], link = '#' } = Astro.props;
---

<article class="work-card" data-aos="fade-up">
  <div class="work-card-image">
    <img src={image} alt={title} loading="lazy" width="504" height="400" />
  </div>
  <div class="work-card-body">
    <h3>{title}</h3>
    <p class="text-section">{description}</p>
    {tags.length > 0 && (
      <ul class="work-tags">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}
  </div>
</article>

<script>
  document.querySelectorAll<HTMLElement>('.work-card').forEach((card) => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const cx = rect.width / 2;
      const cy = rect.height / 2;
      const tiltX = ((y - cy) / cy) * -3;
      const tiltY = ((x - cx) / cx) * 3;
      card.style.transform = `perspective(1200px) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
</script>

<style>
  .work-card {
    display: grid;
    grid-template-columns: clamp(160px, 25%, 280px) 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
    padding: clamp(1.5rem, 3vw, 2.5rem) 0;
    border-bottom: 1px solid var(--border);
    transform-style: preserve-3d;
    will-change: transform;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .work-card-image img {
    width: 100%;
    border-radius: 0.5rem;
    filter: var(--img-filter);
    transition: filter 0.5s ease;
  }

  .work-card:hover .work-card-image img {
    filter: var(--img-filter-hover);
  }

  .work-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .work-card-body h3 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .work-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin-top: 0.25rem;
  }

  .work-tags li {
    font-size: 0.8rem;
    text-transform: lowercase;
    letter-spacing: 0.5px;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    color: var(--text-muted);
    transition: border-color 0.3s;
  }

  .work-card:hover .work-tags li {
    border-color: var(--color-orange-dim, rgba(255,117,24,0.3));
  }

  @media (max-width: 768px) {
    .work-card {
      grid-template-columns: 100px 1fr;
      gap: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .work-card {
      grid-template-columns: 1fr;
    }

    .work-card-image img {
      max-width: 120px;
    }
  }
</style>
