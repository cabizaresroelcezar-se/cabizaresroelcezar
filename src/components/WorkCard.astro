---
interface Props {
  image: string;
  title: string;
  description: string;
  tags?: string[];
  link?: string;
}

const { image, title, description, tags = [], link = '#' } = Astro.props;
---

<article class="work-article" data-aos="fade-up">
  <img src={image} alt={title} class="work-image" loading="lazy" width="504" height="400" />
  <div class="work-text">
    <h3>{title}</h3>
    <p class="text-section font-light leading-relaxed">{description}</p>
    {tags.length > 0 && (
      <div class="work-details">
        <ul>
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
      </div>
    )}
    <a href={link} class="explore-btn">Explore</a>
  </div>
</article>

<script>
  document.querySelectorAll('.work-article .explore-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const details = btn.previousElementSibling as HTMLElement | null;
      if (details && details.classList.contains('work-details')) {
        details.classList.toggle('visible');
      }
    });
  });
</script>

<style>
  .work-article {
    display: flex;
    padding: 5% 0;
    gap: 5%;
    align-items: flex-start;
    border-bottom: 1px solid var(--border);
  }

  .work-image {
    width: 100%;
    max-width: 180px;
    filter: var(--img-filter);
    transition: filter 0.4s ease;
    flex-shrink: 0;
  }

  .work-article:hover .work-image {
    filter: var(--img-filter-hover);
  }

  .work-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .work-text h3 {
    font-size: 2.3rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .work-text p {
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .work-details {
    display: none;
    margin-bottom: 1rem;
  }

  .work-details.visible {
    display: block;
  }

  .work-details ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .work-details ul li {
    color: var(--text-muted);
    font-size: 0.85rem;
    text-transform: lowercase;
    letter-spacing: 1px;
    padding: 4px 10px;
    border: 1px solid var(--services-tag-border, #252525);
  }

  .explore-btn {
    color: var(--color-orange);
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.3s;
    cursor: pointer;
    display: inline-block;
  }

  .explore-btn:hover {
    color: var(--text-primary);
  }

  @media only screen and (max-width: 768px) {
    .work-article {
      flex-direction: column;
      gap: 1.5rem;
    }

    .work-image {
      max-width: 100%;
      width: 120px;
    }

    .work-text h3 {
      font-size: 1.5rem;
    }
  }
</style>
