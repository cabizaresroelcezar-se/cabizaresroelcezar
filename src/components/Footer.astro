<footer>
  <div data-aos="fade-up" class="col">
    <a href="#about-me">
      <img src="/logo.png" alt="cabizaresroelcezar logo" width="180" height="172" loading="lazy" />
    </a>
  </div>
  <div data-aos="fade-up" class="col">
    <address>
      +63<br />
      Quezon City, 1115 / Manila, 1016 <br />
      National Capital Region, Philippines
    </address>
  </div>
  <div data-aos="fade-up" class="col social-col">
    <a href="https://www.facebook.com/cabzcbzrs" target="_blank" rel="noopener noreferrer">
      <img src="/facebook.svg" alt="facebook" loading="lazy" />
    </a>
    <a href="https://www.instagram.com/cabzcbzrs" target="_blank" rel="noopener noreferrer">
      <img src="/instagram.svg" alt="instagram" loading="lazy" />
    </a>
    <a href="https://www.linkedin.com/in/cabizaresroelcezar/" target="_blank" rel="noopener noreferrer">
      <img src="/linkedin.svg" alt="linkedin" loading="lazy" />
    </a>
  </div>
</footer>

<style>
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5% 0 3%;
    border-top: 1px solid var(--border);
    margin-top: 4%;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  address {
    font-style: normal;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 2;
  }

  .social-col {
    flex-direction: row;
    gap: 1.5rem;
    align-items: center;
    justify-content: flex-end;
  }

  .social-col img {
    width: 24px;
    height: 24px;
    opacity: 0.5;
    transition: opacity 0.3s, filter 0.3s;
  }

  :global([data-theme="dark"]) .social-col img {
    filter: invert(1);
  }

  :global([data-theme="light"]) .social-col img {
    filter: invert(0);
  }

  .social-col a:hover img {
    opacity: 1;
  }

  @media only screen and (max-width: 768px) {
    footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .social-col {
      justify-content: flex-start;
    }
  }
</style>
