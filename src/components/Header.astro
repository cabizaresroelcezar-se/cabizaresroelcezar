---
const base = import.meta.env.BASE_URL;
---

<header class="is-hidden">
  <h1>
    <a href={base}>
      <img src={`${base}logo.png`} alt="Roel Cezar Cabizares" width="48" height="46" class="logo-dark" />
      <img src={`${base}logo_light.png`} alt="Roel Cezar Cabizares" width="48" height="46" class="logo-light" />
    </a>
  </h1>

  <nav>
    <a href={`${base}#about-me`}>
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      About
    </a>
    <a href={`${base}#services`}>
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      Services
    </a>
    <a href={`${base}#works`}>
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
      Experience
    </a>
    <a href={`${base}branding`}>
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
      Branding
    </a>
    <!-- <a href="/cv.pdf" target="_blank" rel="noopener noreferrer">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      CV
    </a> -->
    <a href="https://www.linkedin.com/in/cabizaresroelcezar/" target="_blank" rel="noopener noreferrer">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      LinkedIn
    </a>
    <a href={`${base}#contact`}>
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      Contact
    </a>
  </nav>

  <a href="javascript: void(0);" id="mobile-menu-btn" class="menu-toggle" aria-label="Toggle menu">
    <span class="menu-toggle__bar"></span>
    <span class="menu-toggle__bar"></span>
  </a>
</header>

<script>
  // Show/hide header on scroll
  window.addEventListener('scroll', () => {
    const header = document.querySelector('header');
    if (!header) return;
    window.scrollY > 200
      ? header.classList.remove('is-hidden')
      : header.classList.add('is-hidden');
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  menuBtn?.addEventListener('click', () => {
    const header = document.querySelector('header');
    if (menuBtn.classList.contains('active')) {
      header?.classList.remove('responsive');
      menuBtn.classList.remove('active');
    } else {
      header?.classList.add('responsive');
      menuBtn.classList.add('active');
    }
  });

  // Close mobile menu when a nav link is clicked
  document.querySelectorAll('header nav a').forEach((link) => {
    link.addEventListener('click', () => {
      const header = document.querySelector('header');
      header?.classList.remove('responsive');
      menuBtn?.classList.remove('active');
    });
  });

  // IntersectionObserver for active nav links
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const sectionClass = entry.target.classList[0];
        const navLink = document.querySelector(`header nav a[href*='#${sectionClass}']`);
        if (navLink) {
          entry.isIntersecting
            ? navLink.classList.add('active')
            : navLink.classList.remove('active');
        }
      });
    },
    { threshold: 0.25 }
  );

  ['about-me', 'services', 'works', 'contact'].forEach((cls) => {
    const el = document.querySelector(`.${cls}`);
    if (el) observer.observe(el);
  });

  // Hash-based scroll on load
  if (location.hash !== '') {
    document.querySelector(location.hash)?.scrollIntoView();
  }

  window.addEventListener('popstate', () => {
    document.querySelector('header')?.classList.remove('responsive');
    menuBtn?.classList.remove('active');
    if (location.hash !== '') {
      document.querySelector(location.hash)?.scrollIntoView();
    }
  });
</script>

<style>
  header {
    background-color: var(--dock-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    position: fixed;
    z-index: 60;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0.85rem 7.2%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: opacity 0.4s, visibility 0.4s, transform 0.4s;
    opacity: 1;
    visibility: visible;
  }

  header.is-hidden {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-100%);
  }

  header h1 {
    text-align: left;
    line-height: 1;
    flex-shrink: 0;
  }

  header h1 a {
    display: flex;
    align-items: center;
  }

  .logo-light { display: none; }
  .logo-dark { display: block; }
  :global([data-theme="light"]) .logo-dark { display: none; }
  :global([data-theme="light"]) .logo-light { display: block; }

  header nav {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  header nav a {
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 8px 0;
    font-size: var(--fs-2xs);
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 1.5px;
    transition: color 0.3s;
    position: relative;
  }

  .nav-icon {
    flex-shrink: 0;
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  header nav a:hover .nav-icon,
  header nav a.active .nav-icon {
    opacity: 1;
  }

  header nav a::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-orange);
    transition: width 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  header nav a:hover,
  header nav a.active {
    color: var(--text-primary);
  }

  header nav a:hover::after,
  header nav a.active::after {
    width: 100%;
  }

  header nav a:last-of-type {
    color: #000;
    border: solid 1.5px var(--color-orange);
    border-radius: 2rem;
    background-color: var(--color-orange);
    padding: 10px 22px;
    font-weight: 600;
    transition: color 0.3s, border-color 0.3s, background-color 0.3s;
  }

  header nav a:last-of-type::after {
    display: none;
  }

  header nav a:last-of-type:hover,
  header nav a:last-of-type.active {
    color: var(--color-orange);
    border-color: var(--color-orange);
    background-color: transparent;
  }

  /* ── Hamburger toggle ── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
  }

  .menu-toggle__bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .menu-toggle.active .menu-toggle__bar:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .menu-toggle.active .menu-toggle__bar:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  @media only screen and (max-width: 820px) {
    header {
      padding: 0.75rem 1.25rem;
      flex-wrap: wrap;
    }

    header h1 {
      order: 1;
    }

    header h1 img {
      width: 38px;
      height: auto;
    }

    .menu-toggle {
      display: flex;
      order: 2;
      margin-left: auto;
    }

    header nav {
      display: none;
      order: 3;
      flex: none;
    }

    header.responsive {
      padding-bottom: 1.25rem;
    }

    header.responsive nav {
      display: flex;
      flex-direction: column;
      width: 100%;
      gap: 0;
      padding-top: 0.75rem;
      margin-top: 0.75rem;
      border-top: 1px solid var(--border);
    }

    header.responsive nav a {
      padding: 11px 0;
      width: 100%;
      border: none;
      border-radius: 0;
      background: transparent;
      font-size: var(--fs-xs);
    }

    header.responsive nav a::after {
      display: none;
    }

    header.responsive nav a:last-of-type {
      margin-top: 0.5rem;
      width: fit-content;
      align-self: flex-start;
      padding: 10px 22px;
      background-color: var(--color-orange);
      border: solid 1.5px var(--color-orange);
      border-radius: 2rem;
      color: #000;
      font-size: var(--fs-2xs);
    }

    header.responsive nav a:last-of-type:hover {
      background-color: transparent;
      color: var(--color-orange);
    }
  }
</style>
