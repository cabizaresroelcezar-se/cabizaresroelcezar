---
---

<header class="is-hidden">
  <h1>
    <a href="/">
      <img src="/logo.png" alt="Roel Cezar Cabizares" width="64" height="62" />
    </a>
  </h1>

  <nav>
    <a href="#about-me">About Me</a>
    <a href="#services">Services</a>
    <a href="#works">Works</a>
    <a href="/cv.pdf" target="_blank" rel="noopener noreferrer">CV</a>
    <a href="#contact">Contact</a>
  </nav>

  <a href="javascript: void(0);" id="mobile-menu-btn" class="menu-toggle">Menu</a>
</header>

<script>
  // Show/hide header on scroll
  window.addEventListener('scroll', () => {
    const header = document.querySelector('header');
    if (!header) return;
    window.scrollY > 200
      ? header.classList.remove('is-hidden')
      : header.classList.add('is-hidden');
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  menuBtn?.addEventListener('click', () => {
    const header = document.querySelector('header');
    if (menuBtn.classList.contains('active')) {
      header?.classList.remove('responsive');
      menuBtn.classList.remove('active');
    } else {
      header?.classList.add('responsive');
      menuBtn.classList.add('active');
    }
  });

  // IntersectionObserver for active nav links
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const sectionClass = entry.target.classList[0];
        const navLink = document.querySelector(`header nav a[href*='#${sectionClass}']`);
        if (navLink) {
          entry.isIntersecting
            ? navLink.classList.add('active')
            : navLink.classList.remove('active');
        }
      });
    },
    { threshold: 0.25 }
  );

  ['about-me', 'services', 'works', 'contact'].forEach((cls) => {
    const el = document.querySelector(`.${cls}`);
    if (el) observer.observe(el);
  });

  // Hash-based scroll on load
  if (location.hash !== '') {
    document.querySelector(location.hash)?.scrollIntoView();
  }

  window.addEventListener('popstate', () => {
    document.querySelector('header')?.classList.remove('responsive');
    menuBtn?.classList.remove('active');
    if (location.hash !== '') {
      document.querySelector(location.hash)?.scrollIntoView();
    }
  });
</script>

<style>
  header {
    background-color: var(--dock-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: fixed;
    z-index: 9;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 1.1rem 7.2%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: opacity 0.4s, visibility 0.4s;
    opacity: 1;
    visibility: visible;
  }

  header.is-hidden {
    opacity: 0;
    visibility: hidden;
  }

  header h1 {
    text-align: center;
  }

  header nav {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 5%;
  }

  header nav a {
    color: var(--text-secondary);
    display: inline-block;
    padding: 12px 0;
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 1px;
    transition: color 0.4s, text-shadow 0.4s;
  }

  header nav a:hover,
  header nav a.active {
    color: var(--color-orange);
    text-shadow: none;
  }

  header nav a:last-of-type {
    color: #000;
    border: solid 2px var(--color-orange);
    background-color: var(--color-orange);
    padding: 14px 24px;
    transition: color 0.4s, border-color 0.4s, background-color 0.4s, text-shadow 0.4s;
  }

  header nav a:last-of-type:hover,
  header nav a:last-of-type.active {
    color: var(--text-primary);
    border-color: var(--color-orange);
    background-color: transparent;
    text-shadow: unset;
  }

  .menu-toggle {
    display: none;
    color: var(--text-primary);
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    padding: 8px 0;
    text-decoration: none;
  }

  .menu-toggle.active {
    color: #fff;
  }

  @media only screen and (max-width: 768px) {
    .menu-toggle {
      display: block;
    }

    header nav {
      display: none;
    }

    header.responsive {
      flex-wrap: wrap;
      padding-bottom: 1rem;
    }

    header.responsive nav {
      display: flex;
      flex-direction: column;
      width: 100%;
      gap: 0;
      padding-top: 1rem;
    }

    header.responsive nav a {
      padding: 12px 0;
      width: 100%;
    }
  }
</style>
