---
---

<form id="contact-form" class="contact-form" novalidate>
  <p class="form-greeting" data-aos="fade-up">Hello,</p>

  <div class="form-field" data-aos="fade-up">
    <label for="name">My name is</label>
    <input
      type="text"
      id="name"
      name="name"
      placeholder="Enter your name"
      required
      autocomplete="name"
    />
  </div>

  <div class="form-field" data-aos="fade-up">
    <label for="email">Here is my email</label>
    <input
      type="email"
      id="email"
      name="email"
      placeholder="Enter your email address"
      required
      autocomplete="email"
    />
  </div>

  <div class="form-field" data-aos="fade-up">
    <label for="message">I need assistance with</label>
    <textarea
      id="message"
      name="message"
      placeholder="Enter your message"
      rows={4}
      required
    ></textarea>
  </div>

  <div id="form-status" class="form-status" aria-live="polite" hidden></div>

  <div class="form-action" data-aos="fade-up">
    <button type="submit">Send</button>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;

  if (form) {
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        const formData = new FormData(form);
        const response = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' },
        });

        if (response.ok) {
          statusDiv.textContent = 'Message sent successfully! I\'ll get back to you soon.';
          statusDiv.className = 'form-status success';
          statusDiv.hidden = false;
          form.reset();
          setTimeout(() => { statusDiv.hidden = true; }, 5000);
        } else {
          throw new Error('Form submission failed');
        }
      } catch {
        statusDiv.textContent = 'Error sending message. Please try again or contact me directly.';
        statusDiv.className = 'form-status error';
        statusDiv.hidden = false;
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send';
      }
    });
  }
</script>

<style>
  .contact-form {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .form-greeting {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 300;
    color: var(--text-primary);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .form-field label {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 1.15rem;
    font-weight: 300;
    padding: 0.85rem 0 0.6rem;
    transition: border-color 0.3s ease;
    line-height: 1.5;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-bottom-color: var(--color-orange);
    box-shadow: 0 6px 20px -6px var(--color-orange-glow);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-status {
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-align: center;
  }

  .form-status.success {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .form-status.error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .form-action button {
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 1.1rem 3rem;
    background: var(--color-orange);
    color: #000;
    border: 2px solid var(--color-orange);
    border-radius: 2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    width: fit-content;
  }

  .form-action button:hover:not(:disabled) {
    background: transparent;
    color: var(--color-orange);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px var(--color-orange-glow);
  }

  .form-action button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
