---
---

<form id="contact-form" class="contact-form" novalidate>
  <p class="form-greeting" data-aos="fade-up">Hello,</p>

  <!-- Honeypot — hidden from real users, catches bots -->
  <div class="form-hp" aria-hidden="true" tabindex="-1">
    <input type="text" name="_honey" tabindex="-1" autocomplete="off" />
  </div>

  <div class="form-field" data-aos="fade-up">
    <label for="name">My name is</label>
    <input
      type="text"
      id="name"
      name="name"
      placeholder="Enter your name"
      required
      minlength="2"
      maxlength="80"
      autocomplete="name"
    />
    <span class="field-error" id="name-error" aria-live="polite"></span>
  </div>

  <div class="form-field" data-aos="fade-up">
    <label for="email">Here is my email</label>
    <input
      type="email"
      id="email"
      name="email"
      placeholder="Enter your email address"
      required
      maxlength="120"
      autocomplete="email"
    />
    <span class="field-error" id="email-error" aria-live="polite"></span>
  </div>

  <div class="form-field" data-aos="fade-up">
    <label for="message">I need assistance with</label>
    <textarea
      id="message"
      name="message"
      placeholder="Enter your message"
      rows={4}
      required
      minlength="10"
      maxlength="2000"
    ></textarea>
    <span class="field-error" id="message-error" aria-live="polite"></span>
  </div>

  <div id="form-status" class="form-status" aria-live="polite" hidden></div>

  <div class="form-action" data-aos="fade-up">
    <button type="submit">Send</button>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;

  /* ── Helpers ── */
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  let formLoadedAt = Date.now();

  function showFieldError(fieldId: string, msg: string) {
    const el = document.getElementById(`${fieldId}-error`);
    if (el) el.textContent = msg;
    document.getElementById(fieldId)?.classList.add('field-invalid');
  }

  function clearFieldError(fieldId: string) {
    const el = document.getElementById(`${fieldId}-error`);
    if (el) el.textContent = '';
    document.getElementById(fieldId)?.classList.remove('field-invalid');
  }

  function validateField(fieldId: string): boolean {
    const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement;
    if (!field) return true;
    const val = field.value.trim();

    if (fieldId === 'name') {
      if (!val || val.length < 2) { showFieldError(fieldId, 'Please enter your name (at least 2 characters).'); return false; }
      if (val.length > 80) { showFieldError(fieldId, 'Name is too long.'); return false; }
    }
    if (fieldId === 'email') {
      if (!val) { showFieldError(fieldId, 'Please enter your email address.'); return false; }
      if (!EMAIL_RE.test(val)) { showFieldError(fieldId, 'Please enter a valid email address.'); return false; }
    }
    if (fieldId === 'message') {
      if (!val || val.length < 10) { showFieldError(fieldId, 'Please enter a message (at least 10 characters).'); return false; }
      if (val.length > 2000) { showFieldError(fieldId, 'Message is too long (max 2000 characters).'); return false; }
    }
    clearFieldError(fieldId);
    return true;
  }

  /* ── Live inline validation ── */
  ['name', 'email', 'message'].forEach((id) => {
    const el = document.getElementById(id);
    el?.addEventListener('blur', () => validateField(id));
    el?.addEventListener('input', () => {
      if (document.getElementById(`${id}-error`)?.textContent) validateField(id);
    });
  });

  /* ── Submit handler ── */
  if (form) {
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      /* Bot timing check — real users take > 3s */
      if (Date.now() - formLoadedAt < 3000) return;

      /* Honeypot check */
      const honey = form.querySelector('input[name="_honey"]') as HTMLInputElement;
      if (honey && honey.value) return;

      /* Validate all fields */
      const fields = ['name', 'email', 'message'];
      const allValid = fields.map(validateField).every(Boolean);
      if (!allValid) return;

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        const formData = new FormData(form);
        /* Remove honeypot from submission */
        formData.delete('_honey');

        const response = await fetch('https://formsubmit.co/ajax/cabizaresroelcezar@gmail.com', {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' },
        });

        if (response.ok) {
          statusDiv.textContent = 'Message sent successfully! I\'ll get back to you soon.';
          statusDiv.className = 'form-status success';
          statusDiv.hidden = false;
          form.reset();
          fields.forEach(clearFieldError);
          formLoadedAt = Date.now();
          setTimeout(() => { statusDiv.hidden = true; }, 5000);
        } else {
          throw new Error('Form submission failed');
        }
      } catch {
        statusDiv.textContent = 'Error sending message. Please try again or contact me directly.';
        statusDiv.className = 'form-status error';
        statusDiv.hidden = false;
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send';
      }
    });
  }
</script>

<style>
  /* ── Honeypot (hidden from real users) ── */
  .form-hp {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .contact-form {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .form-greeting {
    font-size: var(--fs-lg);
    font-weight: 300;
    color: var(--text-primary);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .form-field label {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 1.15rem;
    font-weight: 300;
    padding: 0.85rem 0 0.6rem;
    transition: border-color 0.3s ease;
    line-height: 1.5;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-bottom-color: var(--color-orange);
    box-shadow: 0 6px 20px -6px var(--color-orange-glow);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* ── Field error messages ── */
  .field-error {
    font-size: 0.8rem;
    color: #ef4444;
    min-height: 1.2em;
    margin-top: 0.25rem;
    transition: opacity 0.2s;
  }

  .field-invalid {
    border-bottom-color: #ef4444 !important;
  }

  .form-status {
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-align: center;
  }

  .form-status.success {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .form-status.error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .form-action button {
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 1.1rem 3rem;
    background: var(--color-orange);
    color: #000;
    border: 2px solid var(--color-orange);
    border-radius: 2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    width: fit-content;
  }

  .form-action button:hover:not(:disabled) {
    background: transparent;
    color: var(--color-orange);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px var(--color-orange-glow);
  }

  .form-action button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
