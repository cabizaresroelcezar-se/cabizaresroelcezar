---
// Contact form with Formspree integration
// Update YOUR_FORM_ID with your actual Formspree form ID
// Get one at https://formspree.io/
---

<form id="contact-form" class="contact-form space-y-4 max-w-3xl mx-auto">
  <div class="form-group" data-aos="fade-up">
    <label class="form-label">Hello,</label>
  </div>

  <div class="form-group" data-aos="fade-up">
    <label for="name" class="form-label">My name is</label>
    <input
      type="text"
      id="name"
      name="name"
      placeholder="Enter your name"
      required
      class="form-input"
    />
  </div>

  <div class="form-group" data-aos="fade-up">
    <label for="email" class="form-label">Here is my email</label>
    <input
      type="email"
      id="email"
      name="email"
      placeholder="Enter your email address"
      required
      class="form-input"
    />
  </div>

  <div class="form-group" data-aos="fade-up">
    <label for="message" class="form-label">I need assistance with</label>
    <textarea
      id="message"
      name="message"
      placeholder="Enter your message"
      rows="6"
      required
      class="form-input form-textarea"
    ></textarea>
  </div>

  <div id="form-status" class="hidden rounded-lg p-4 text-center font-medium text-white"></div>

  <div class="form-group" data-aos="fade-up">
    <button type="submit" class="form-button w-full">
      Send
    </button>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;

  if (form) {
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      try {
        const formData = new FormData(form);

        // Using Formspree - replace YOUR_FORM_ID with your actual form ID
        // Get your form ID at https://formspree.io/
        const response = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json',
          },
        });

        if (response.ok) {
          statusDiv.textContent = '✓ Message sent successfully! I\'ll get back to you soon.';
          statusDiv.classList.remove('hidden', 'bg-red-900', 'text-red-300');
          statusDiv.classList.add('bg-green-900', 'text-green-300');
          form.reset();
          
          // Clear status message after 5 seconds
          setTimeout(() => {
            statusDiv.classList.add('hidden');
          }, 5000);
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        statusDiv.textContent = '✗ Error sending message. Please try again or contact me directly.';
        statusDiv.classList.remove('hidden', 'bg-green-900', 'text-green-300');
        statusDiv.classList.add('bg-red-900', 'text-red-300');
      }
    });
  }
</script>

<style>
  .form-group {
    opacity: 0;
    transform: translateY(1rem);
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .form-group:nth-child(1) {
    animation-delay: 0s;
  }

  .form-group:nth-child(2) {
    animation-delay: 0.1s;
  }

  .form-group:nth-child(3) {
    animation-delay: 0.2s;
  }

  .form-group:nth-child(4) {
    animation-delay: 0.3s;
  }

  .form-group:nth-child(5) {
    animation-delay: 0.4s;
  }

  .form-group:nth-child(6) {
    animation-delay: 0.5s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .form-label {
    display: block;
    color: var(--text-primary);
    font-weight: 300;
    margin-bottom: 0;
    font-size: 1rem;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    background-color: transparent;
    border: none;
    border-bottom: 2px solid var(--border);
    color: var(--text-primary);
    padding: 0.5rem 0;
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-muted);
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-bottom-color: var(--color-orange);
  }

  .form-textarea {
    resize: vertical;
  }

  .form-button {
    padding: 1rem 3rem;
    background-color: var(--color-orange);
    color: #000;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: solid 2px var(--color-orange);
    cursor: pointer;
    transition: all 0.4s ease;
  }

  .form-button:hover {
    background-color: transparent;
    border-color: var(--color-orange);
    color: var(--text-primary);
    text-shadow: none;
  }

  #form-status {
    background-color: rgba(0, 0, 0, 0.5);
    border: 1px solid currentColor;
  }
</style>
