---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found | Roel Cezar Cabizares">
  <main class="error-page">
    <div class="error-bg" aria-hidden="true">
      <div class="error-shape">
        <div class="orb"></div>
        <div class="orb"></div>
      </div>
    </div>

    <div class="error-content">
      <p class="error-label">Error</p>
      <h1 class="error-code">404</h1>
      <p class="error-message">
        The page you're looking for doesn't exist — or it moved somewhere else entirely.
      </p>
      <a href="/" class="error-cta">Back to Home</a>
    </div>
  </main>
</BaseLayout>

<style>
  .error-page {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
    background: var(--bg);
  }

  /* ── Background shape (same as hero) ── */
  .error-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .error-shape {
    position: absolute;
    top: 50%;
    left: 55%;
    width: 420px;
    height: 420px;
    transform: translate(-50%, -50%);
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    background: var(--hero-shape-bg);
    backdrop-filter: blur(60px);
    -webkit-backdrop-filter: blur(60px);
    border: 1px solid var(--border);
    animation: morphShape 12s ease-in-out infinite, float 6s ease-in-out infinite;
    opacity: 0.5;
  }

  @keyframes morphShape {
    0%, 100% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
    25%      { border-radius: 58% 42% 38% 62% / 52% 48% 52% 48%; }
    50%      { border-radius: 45% 55% 62% 38% / 38% 62% 38% 62%; }
    75%      { border-radius: 62% 38% 45% 55% / 55% 45% 62% 38%; }
  }

  @keyframes float {
    0%, 100% { transform: translate(-50%, -50%) translateX(0); }
    50%      { transform: translate(-50%, calc(-50% - 18px)) translateX(8px); }
  }

  .error-shape .orb {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 117, 24, 0.25), transparent 70%);
    filter: blur(20px);
  }

  .error-shape .orb:nth-child(1) {
    width: 100px;
    height: 100px;
    top: 20%;
    left: 15%;
    animation: orb-drift 8s ease-in-out infinite;
  }

  .error-shape .orb:nth-child(2) {
    width: 70px;
    height: 70px;
    top: 55%;
    left: 60%;
    animation: orb-drift 10s ease-in-out infinite reverse;
  }

  @keyframes orb-drift {
    0%, 100% { transform: translate(0, 0); }
    33%      { transform: translate(15px, -12px); }
    66%      { transform: translate(-10px, 8px); }
  }

  /* ── Content ── */
  .error-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 520px;
  }

  .error-label {
    font-size: var(--fs-2xs);
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 1rem;
  }

  .error-code {
    font-size: clamp(6rem, 18vw, 12rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 2px var(--outline-stroke);
    text-stroke: 2px var(--outline-stroke);
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--color-orange) 60%,
      #ff9a44 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1.5rem;
  }

  .error-message {
    font-size: clamp(1rem, 1.4vw, 1.1875rem);
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
  }

  .error-cta {
    display: inline-block;
    font-size: var(--fs-2xs);
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #000;
    background: var(--color-orange);
    border: 1.5px solid var(--color-orange);
    border-radius: 2rem;
    padding: 0.85rem 2.25rem;
    transition: color 0.3s, background-color 0.3s;
    text-decoration: none;
  }

  .error-cta:hover {
    color: var(--color-orange);
    background: transparent;
  }

  @media (max-width: 768px) {
    .error-shape {
      width: 260px;
      height: 260px;
      opacity: 0.35;
    }
  }
</style>
