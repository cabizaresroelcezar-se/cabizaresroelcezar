---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SpatialDock from '../components/SpatialDock.astro';
import SpatialHero from '../components/SpatialHero.astro';
import GlassCard from '../components/GlassCard.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import WorkCard from '../components/WorkCard.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Roel Cezar Cabizares - Front-end Developer & Designer">
  <!-- Legacy header (hidden on desktop, fallback for noscript) -->
  <Header />
  <!-- Spatial Dock replaces traditional nav -->
  <SpatialDock />

  <main>
    <!-- Spatial Hero -->
    <SpatialHero
      heading="Hi there,"
      subheading="I'm Roel Cezar Cabizares"
      description="I'm a software engineer specializing in front-end development, UI/UX, and digital experience."
    />

    <!-- About Me Section -->
    <section id="about-me" class="about-me section-wrapper">
      <div class="content about-grid">
        <div class="about-text">
          <h2 class="section-title" data-aos="fade-right">About Me</h2>
          <div class="about-me_img-mobile" data-aos="fade-up">
            <img src="/cabz-img.jpg" alt="Roel Cezar Cabizares" class="mobile-portrait" loading="lazy" />
          </div>
          <p class="content-paragraph" data-aos="fade-up">
            Hello, I'm a software engineer &amp; developer based in the Philippines, and I conserve an
            expressive passion for user interface, visual design, and creating intuitive, dynamic user experiences.
          </p>
          <p class="content-paragraph" data-aos="fade-up">
            Given enough coffee and inexhaustible enthusiasm, I am easily inspired and more willing to
            follow my ideas wherever they take me. I'm a dynamic person, an expressive, talented spirit
            with an innate ability to entertain and inspire. I'm never satisfied with just coming up
            with ideas. Instead, I have an almost impulsive need to act on them.
          </p>
          <p class="content-paragraph" data-aos="fade-up">
            I'm also experienced in and completed various responsive website designs,
            front-end assets, and custom WordPress builds.
          </p>
          <p data-aos="fade-up">
            <a href="#services" class="content-link">Learn more</a>
          </p>
        </div>
        <div class="about-image" data-aos="fade-left">
          <img src="/cabz-img.jpg" alt="Roel Cezar Cabizares" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services section-wrapper">
      <h2 class="section-title" data-aos="fade-right">Services</h2>
      <div class="content">
        <div class="services-card-wrapper glass-cards-row" data-aos="fade-right">
          <GlassCard
            icon="/icons/web-development.svg"
            title="Web Development"
            description="Design and develop a user-centric website and modern interfaces for digital products or services that will help transfer the business strengths and visual assets to the interweb."
            type="web-development"
          />
          <GlassCard
            icon="/icons/design.svg"
            title="Branding & Design"
            description="Full strategy design and execution for new and refresh brand projects, including positioning, brand architecture and identity."
            type="design"
          />
          <GlassCard
            icon="/icons/digital-marketing.svg"
            title="Digital Marketing"
            description="Design for new and existing solutions, including UI/UX, visual design, and marketing support accessible to benefit business growth."
            type="digital-marketing"
          />
        </div>
      </div>
      <div class="content services-bottom">
        <div class="services-list">
          <h3 data-aos="fade-up">Website Design</h3>
          <h3 data-aos="fade-up">Website Development</h3>
          <h3 data-aos="fade-up">User Experience Interaction</h3>
          <h3 data-aos="fade-up">User Interface Design</h3>
          <h3 data-aos="fade-up">Figma Wireframes</h3>
          <h3 data-aos="fade-up">Figma Low-fidelity Prototypes</h3>
          <h3 data-aos="fade-up">Visual &amp; Identity Design</h3>
          <h3 data-aos="fade-up">Visual Layout Design</h3>
          <h3 data-aos="fade-up">WordPress Website Design</h3>
          <h3 data-aos="fade-up">WordPress Custom Code</h3>
        </div>
        <p data-aos="fade-up" class="services-cta">
          Let's talk and save time;<br />
          Click on a service to find out how.
        </p>
      </div>
    </section>

    <!-- Works Section -->
    <section id="works" class="works section-wrapper">
      <h2 class="section-title" data-aos="fade-right">I'm currently working as a Software Engineer</h2>
      <div class="content">
        <div class="work_section-employer">
          <article class="work-article" data-aos="fade-up">
            <img src="/yondu_logo.png" alt="Yondu Logo" width="100" height="340" class="work-image" loading="lazy" />
            <div class="work-text">
              <h3>Yondu Inc.</h3>
              <p class="text-section font-light leading-relaxed">
                My bread and butter. Presently functioning and deployed as a .NET developer for Yondu's business
                client, operates with IT professionals that are interdependent in a team, practices agile
                methodologies, and directly supports and enhances the current system design approach for the
                advancement of the company's business objectives.
              </p>
              <div class="work-details">
                <ul>
                  <li>.net</li>
                  <li>c# programming language</li>
                  <li>html</li>
                  <li>css</li>
                  <li>javascript</li>
                  <li>optimizely</li>
                </ul>
              </div>
              <a href="#" class="explore-btn">Explore</a>
            </div>
          </article>
        </div>

        <h2 class="subsection-title" data-aos="fade-right">Personal Branding</h2>

        <h2 class="subsection-title" data-aos="fade-right">Projects</h2>
        <p class="text-section project_section-subtitle" data-aos="fade-up">
          Mostly a trip down memory lane. To be expanded.
        </p>

        <WorkCard
          image="/rescue-8.jpg"
          title="Rescue 8 Trading Philippines, Inc."
          description="WooCommerce-powered WordPress build a website with a custom template and content, designed to showcase product and services offered by the company with an online purchase feature for the convenience of the page visitors and potential consumers."
          tags={['wordpress', 'custom theme', 'wordpress plugin']}
        />
        <WorkCard
          image="/ride-slow.jpg"
          title="Ride Slow Lifestyle"
          description="Custom image-centered page layout with WooCommerce store, plugin-based photo gallery, and integration of real-time Facebook messaging functionality to help with the promotion and engagement of the site."
          tags={['wordpress', 'woocommerce', 'custom css', 'facebook api']}
        />
        <WorkCard
          image="/adyo.jpg"
          title="Adyó Philippines"
          description="Brand identity project for an outdoor brand startup Adyó. It's a full-scale trademark identity that delivers optimism and displays visual element that focuses on a vividly inviting and stylishly outdoor look and feel."
          tags={['brand identity', 'visual design', 'typography', 'logo design']}
        />

        <section class="project_section-hobby">
          <h2 class="subsection-title" data-aos="fade-right">Side Projects &amp; Hobby</h2>
          <p class="text-section project_section-subtitle" data-aos="fade-up">
            Things I build for fun and personal exploration.
          </p>
          <article class="work-article" data-aos="fade-up">
            <img src="/keycabz_logo.png" alt="thy keycabz Logo" width="100" height="340" class="work-image" loading="lazy" />
            <div class="work-text">
              <h3>thy keycabz</h3>
              <p class="text-section font-light leading-relaxed">
                A personal hobby project centered around mechanical keyboards  exploration of switches, keycaps,
                sound profiles, and custom builds. A passion project that merges craftsmanship with tech aesthetics.
              </p>
              <div class="work-details">
                <ul>
                  <li>mechanical keyboards</li>
                  <li>custom builds</li>
                  <li>sound design</li>
                  <li>keycap art</li>
                </ul>
              </div>
              <a href="#" class="explore-btn">Explore</a>
            </div>
          </article>
        </section>

        <p data-aos="fade-up" class="works-cta">
          If you are thinking about hiring me or<br />
          would like to discuss a project, get in touch with me<br />
          <a href="#contact" class="content-link">here.</a>
        </p>
      </div>
    </section>

    <!-- Process Section -->
    <section class="workflow-process section-wrapper">
      <h2 class="section-title" data-aos="fade-right">Process</h2>
      <div class="content">
        <p class="content-paragraph" data-aos="fade-up"></p>
      </div>
    </section>

    <!-- Kudos Section -->
    <section class="kudos section-wrapper">
      <h2 class="section-title" data-aos="fade-right">Kudos</h2>
      <div class="content">
        <p class="kudos_section-content" data-aos="fade-up">
          It's very rare these days to make anything great all on your own. I have only included work that
          I had a large contribution to, but whether it's design, ideas, UX, process, software
          engineering, mentorship, advice, or creative direction, the following people have influenced my
          growth and career path in a massive way:
          <a href="https://www.linkedin.com/in/leoabasjr/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Leopoldo Abas Jr.</a>,
          <a href="https://www.linkedin.com/in/jamesolano/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">James Nelson Olaño</a>,
          <a href="https://www.linkedin.com/in/kevin-juanillo-1835b9b9/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Kevin Juanillo</a>,
          <a href="https://www.linkedin.com/in/marian-rae-alvarado-3057b8190/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Marian Rae Alvarado</a>,
          <a href="https://www.linkedin.com/in/jeremiah-diaz-097556a4/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Jeremiah Diaz</a>,
          <a href="https://www.linkedin.com/in/eric-francis-casaljay-461418150/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Eric Francis Casaljay</a>
          and last but not least
          <a href="https://www.linkedin.com/in/ma-clarizza-folloso-ab418b1aa/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Ma. Clarizza Folloso</a>.
          THANK YOU.
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact section-wrapper">
      <h2 class="section-title" data-aos="fade-right">Contact</h2>
      <div class="content">
        <ContactForm />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  /* services-list: click to scroll contact and prefill message */
  const msg = document.querySelector('#message') as HTMLTextAreaElement | null;
  document.querySelectorAll('.services-list h3').forEach((s) => {
    (s as HTMLElement).onclick = function () {
      document.querySelector('.contact')?.scrollIntoView({ behavior: 'smooth' });
      if (msg) {
        msg.value = (this as HTMLElement).textContent + ' ';
        msg.style.color = '#fefefe';
      }
    };
  });
  if (msg) {
    msg.onkeydown = function () {
      (this as HTMLTextAreaElement).style.color = '#f8f8f8';
    };
  }

  /* explore toggle for inline articles (Yondu, keycabz) */
  document.querySelectorAll('.work-article .explore-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const details = (btn as HTMLElement).previousElementSibling as HTMLElement | null;
      if (details && details.classList.contains('work-details')) {
        details.classList.toggle('visible');
      }
    });
  });
</script>

<style>
  .section-title {
    color: var(--text-primary);
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 8rem;
  }

  .hero h2 {
    font-size: 5.5rem;
    font-weight: 700;
    line-height: 1.1;
    cursor: default;
    white-space: nowrap;
    color: var(--text-primary);
  }

  .hero h2 span {
    display: block;
  }

  .scroll-arrow {
    margin-top: 4rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(10px); }
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8%;
    align-items: start;
  }

  .about-image img {
    width: 100%;
    filter: var(--img-filter);
    transition: filter 0.4s;
  }

  .about-image img:hover {
    filter: var(--img-filter-hover);
  }

  .about-me_img-mobile {
    display: none;
    margin-bottom: 2rem;
  }

  .mobile-portrait {
    width: 100%;
    max-width: 300px;
  }

  /* Services */
  .services-card-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .services-bottom {
    display: flex;
    align-items: flex-start;
    gap: 8%;
  }

  .services-list {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5%;
  }

  .services-list h3 {
    font-size: 1.2rem;
    font-weight: 300;
    letter-spacing: 1px;
    padding: 14px;
    border: solid 2px var(--services-tag-border);
    margin-bottom: 3%;
    cursor: pointer;
    transition: all 0.4s;
    color: var(--text-primary);
  }

  .services-list h3:hover {
    color: var(--services-tag-hover-text);
    border-color: var(--color-orange);
    background-color: var(--color-orange);
    text-shadow: none;
  }

  .services-cta {
    font-size: 1.3rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 280px;
  }

  /* Works */
  .work_section-employer {
    margin-bottom: 4%;
  }

  .subsection-title {
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--text-primary);
    padding: 3% 0 2%;
  }

  .project-subtitle {
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .project_section-hobby {
    margin-top: 6%;
  }

  .works-cta {
    font-size: 1.3rem;
    line-height: 1.8;
    color: var(--text-secondary);
    padding: 4% 0;
  }

  /* Kudos */
  .kudos-content {
    color: var(--text-secondary);
    line-height: 2;
    max-width: 80ch;
  }

  .kudos-link {
    color: var(--color-orange);
    text-decoration: underline;
    transition: opacity 0.3s;
  }

  .kudos-link:hover {
    opacity: 0.7;
  }

  /* Shared */
  .content {
    width: 100%;
  }

  /* Work article (inline) */
  .work_section-employer .work-article {
    display: flex;
    padding: 3% 0 5%;
    gap: 5%;
    align-items: flex-start;
    border-bottom: 1px solid var(--border);
  }

  .work_section-employer .work-image {
    width: 100px;
    flex-shrink: 0;
    filter: var(--img-filter);
    transition: filter 0.4s ease;
  }

  .work_section-employer .work-article:hover .work-image {
    filter: var(--img-filter-hover);
  }

  .work_section-employer .work-text h3 {
    font-size: 2.3rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .project_section-hobby .work-article {
    display: flex;
    padding: 3% 0 5%;
    gap: 5%;
    align-items: flex-start;
    border-bottom: 1px solid var(--border);
  }

  .project_section-hobby .work-image {
    width: 100px;
    flex-shrink: 0;
    filter: var(--img-filter);
    transition: filter 0.4s ease;
  }

  .project_section-hobby .work-article:hover .work-image {
    filter: var(--img-filter-hover);
  }

  .project_section-hobby .work-text h3 {
    font-size: 2.3rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  /* Responsive */
  @media only screen and (max-width: 768px) {
    .hero h2 {
      font-size: 2.5rem;
      white-space: normal;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-image {
      display: none;
    }

    .about-me_img-mobile {
      display: block;
    }

    .services-bottom {
      flex-direction: column;
    }

    .services-cta {
      max-width: 100%;
    }

    .work_section-employer .work-article,
    .project_section-hobby .work-article {
      flex-direction: column;
    }

    .subsection-title {
      font-size: 1.8rem;
    }

    .glass-cards-row {
      flex-direction: column;
      align-items: center;
    }
  }

  /* ── Glassmorphism card row ── */
  .glass-cards-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    padding: 0 0 4% 0;
  }
</style>
