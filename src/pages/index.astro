            <div class="cryptobuds-links" data-aos="fade-up" data-aos-delay="200">
              <a href="https://www.facebook.com/CryptobudsNFT" target="_blank" rel="noopener noreferrer" class="content-link">Facebook</a>
              <a href="https://linktr.ee/Cryptobuds" target="_blank" rel="noopener noreferrer" class="content-link">Linktree</a>
