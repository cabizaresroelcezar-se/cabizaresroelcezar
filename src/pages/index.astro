    <!-- Yo-Bi — Supporting & Managing ──────────────────── -->
    <section class="section-panel yobi-section">
      <span class="outline-text outline-text--left" aria-hidden="true">Yo-Bi</span>
      <div class="section-inner">
        <div class="yobi-hero">
