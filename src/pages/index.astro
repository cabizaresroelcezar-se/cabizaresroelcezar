---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SpatialDock from '../components/SpatialDock.astro';
import SpatialHero from '../components/SpatialHero.astro';
import GlassCard from '../components/GlassCard.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Roel Cezar Cabizares - Front-end Developer & Designer">
  <Header />
  <SpatialDock />

  <main>
    <!-- Hero (greetings unchanged) -->
    <SpatialHero
      heading="Hi there,"
      subheading="I'm Roel Cezar Cabizares"
      description="I'm a software engineer specializing in front-end development, UI/UX, and digital experience."
    />

    <!-- About Me -->
    <section id="about-me" class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">About Me</span>
      <div class="section-inner">
        <div class="about-grid">
          <div class="about-text">
            <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">About Me</h2>
            <div class="about-me_img-mobile" data-aos="fade-up">
              <img src="/cabz-img.jpg" alt="Roel Cezar Cabizares" class="mobile-portrait" loading="lazy" />
            </div>
            <p class="content-paragraph" data-aos="reveal-left" data-aos-duration="700">
              Hello, I'm a <strong>software engineer &amp; developer</strong> based in the Philippines, and I conserve an
              expressive passion for <strong>user interface, visual design</strong>, and creating <strong>intuitive, dynamic user experiences</strong>.
            </p>
            <p class="content-paragraph" data-aos="reveal-left" data-aos-duration="700" data-aos-delay="100">
              Given enough coffee and inexhaustible enthusiasm, I am <strong>easily inspired</strong> and more willing to
              follow my ideas wherever they take me. I'm a <strong>dynamic person</strong>, an expressive, talented spirit
              with an innate ability to entertain and inspire. I'm never satisfied with just coming up
              with ideas. Instead, I have an <strong>almost impulsive need to act on them</strong>.
            </p>
            <p class="content-paragraph" data-aos="reveal-left" data-aos-duration="700" data-aos-delay="200">
              I'm also experienced in and completed various <strong>responsive website designs</strong>,
              <strong>front-end assets</strong>, and <strong>custom WordPress builds</strong>.
            </p>
            <p class="about-cta" data-aos="fade-up" data-aos-delay="300">
              <a href="#services" class="content-link">Learn more</a>
            </p>
          </div>
          <div class="about-image" data-aos="reveal-right" data-aos-duration="900">
            <img src="/cabz-img.jpg" alt="Roel Cezar Cabizares" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="section-panel section-panel--alt">
      <span class="outline-text outline-text--right" aria-hidden="true">Services</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Services</h2>

        <div class="services-grid" data-aos="scale-in" data-aos-duration="800">
          <GlassCard
            icon="/icons/web-development.svg"
            title="Web Development"
            description="Design and develop a user-centric website and modern interfaces for digital products or services that will help transfer the business strengths and visual assets to the interweb."
            type="web-development"
          />
          <GlassCard
            icon="/icons/design.svg"
            title="Branding & Design"
            description="Full strategy design and execution for new and refresh brand projects, including positioning, brand architecture and identity."
            type="design"
          />
          <GlassCard
            icon="/icons/digital-marketing.svg"
            title="Digital Marketing"
            description="Design for new and existing solutions, including UI/UX, visual design, and marketing support accessible to benefit business growth."
            type="digital-marketing"
          />
        </div>

        <div class="services-bottom" data-aos="fade-up" data-aos-delay="200">
          <div class="services-tags">
            <button type="button" class="service-tag">Website Design</button>
            <button type="button" class="service-tag">Website Development</button>
            <button type="button" class="service-tag">User Experience Interaction</button>
            <button type="button" class="service-tag">User Interface Design</button>
            <button type="button" class="service-tag">Figma Wireframes</button>
            <button type="button" class="service-tag">Figma Low-fidelity Prototypes</button>
            <button type="button" class="service-tag">Visual &amp; Identity Design</button>
            <button type="button" class="service-tag">Visual Layout Design</button>
            <button type="button" class="service-tag">WordPress Website Design</button>
            <button type="button" class="service-tag">WordPress Custom Code</button>
          </div>
          <p class="services-cta">
            Let's talk and save time;<br />
            Click on a service to find out how.
          </p>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section id="works" class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">Experience</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">I'm currently working as a Software Engineer</h2>

        <!-- Current employer -->
        <article class="employer-card" data-aos="reveal-left" data-aos-duration="700">
          <img src="/yondu_logo.png" alt="Yondu Logo" width="80" height="80" class="employer-logo" loading="lazy" />
          <div class="employer-text">
            <h3>Yondu Inc.</h3>
            <p class="text-section">
              My bread and butter. Presently functioning and deployed as a <strong>.NET developer</strong> for Yondu's business
              client, operates with IT professionals that are interdependent in a team, practices <strong>agile
              methodologies</strong>, and directly supports and enhances the current <strong>system design approach</strong> for the
              advancement of the company's business objectives.
            </p>
            <div class="work-details">
              <ul>
                <li>.net</li>
                <li>c# programming language</li>
                <li>html</li>
                <li>css</li>
                <li>javascript</li>
                <li>optimizely</li>
              </ul>
            </div>
            <button type="button" class="explore-btn">Explore</button>
          </div>
        </article>

        <p data-aos="fade-up" class="works-cta">
          If you are thinking about <strong>hiring me</strong> or
          would like to <strong>discuss a project</strong>, get in touch with me
          <a href="#contact" class="content-link">here.</a>
        </p>
      </div>
    </section>

    <!-- Projects -->
    <section class="section-panel section-panel--alt">
      <span class="outline-text outline-text--right" aria-hidden="true">Projects</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="700">Projects</h2>
        <p class="text-section project_section-subtitle" data-aos="fade-up">
          Mostly a trip down memory lane. To be expanded.
        </p>

        <div class="project-track">
          <article class="project-card" data-aos="fade-up">
            <div class="project-card__image">
              <img src="/rescue-8.jpg" alt="Rescue 8 Trading Philippines, Inc." loading="lazy" width="800" height="500" />
            </div>
            <div class="project-card__body">
              <h3 class="project-card__title">Rescue 8 Trading Philippines, Inc.</h3>
              <p class="text-section">WooCommerce-powered WordPress build a website with a custom template and content, designed to showcase product and services offered by the company with an online purchase feature for the convenience of the page visitors and potential consumers.</p>
              <ul class="project-card__tags">
                <li>wordpress</li><li>custom theme</li><li>wordpress plugin</li>
              </ul>
            </div>
          </article>

          <article class="project-card" data-aos="fade-up" data-aos-delay="100">
            <div class="project-card__image">
              <img src="/ride-slow.jpg" alt="Ride Slow Lifestyle" loading="lazy" width="800" height="500" />
            </div>
            <div class="project-card__body">
              <h3 class="project-card__title">Ride Slow Lifestyle</h3>
              <p class="text-section">Custom image-centered page layout with WooCommerce store, plugin-based photo gallery, and integration of real-time Facebook messaging functionality to help with the promotion and engagement of the site.</p>
              <ul class="project-card__tags">
                <li>wordpress</li><li>woocommerce</li><li>custom css</li><li>facebook api</li>
              </ul>
            </div>
          </article>

          <article class="project-card" data-aos="fade-up" data-aos-delay="200">
            <div class="project-card__image">
              <img src="/adyo.jpg" alt="Adyó Philippines" loading="lazy" width="800" height="500" />
            </div>
            <div class="project-card__body">
              <h3 class="project-card__title">Adyó Philippines</h3>
              <p class="text-section">Brand identity project for an outdoor brand startup Adyó. It's a full-scale trademark identity that delivers optimism and displays visual element that focuses on a vividly inviting and stylishly outdoor look and feel.</p>
              <ul class="project-card__tags">
                <li>brand identity</li><li>visual design</li><li>typography</li><li>logo design</li>
              </ul>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- thy keycabz — Featured ──────────────────────── -->
    <section class="section-panel keycabz-section">
      <span class="outline-text outline-text--left" aria-hidden="true">keycabz</span>
      <div class="section-inner">
        <div class="keycabz-hero">
          <div class="keycabz-text">
            <p class="keycabz-label" data-aos="fade-up">Hobby-turned-Business</p>
            <h2 class="section-title keycabz-title" data-aos="morph-up" data-aos-duration="800">
              thy keycabz
            </h2>
            <p class="content-paragraph" data-aos="reveal-left" data-aos-duration="700">
              What started as a weekend obsession with <strong>mechanical keyboards</strong> quickly evolved into something
              bigger — a full passion project exploring <strong>switch modding, sound tuning, keycap artistry</strong>,
              and the craft of the perfect custom build.
            </p>
            <p class="content-paragraph" data-aos="reveal-left" data-aos-duration="700" data-aos-delay="100">
              Every board is a statement piece. From <strong>thocky linears</strong> to <strong>crisp tactiles</strong>,
              each build merges <strong>engineering precision with creative expression</strong> — the intersection
              where tech meets artisanal craftsmanship.
            </p>
            <div class="keycabz-tags" data-aos="fade-up" data-aos-delay="200">
              <span class="keycabz-tag">Custom Builds</span>
              <span class="keycabz-tag">Sound Design</span>
              <span class="keycabz-tag">Switch Modding</span>
              <span class="keycabz-tag">Keycap Art</span>
              <span class="keycabz-tag">Lubing &amp; Tuning</span>
              <span class="keycabz-tag">Thock Culture</span>
            </div>
          </div>
          <div class="keycabz-visual" data-aos="scale-in" data-aos-duration="900">
            <div class="keycabz-logo-frame">
              <img src="/keycabz_logo.png" alt="thy keycabz" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Statement -->
    <section class="section-panel section-panel--alt statement-panel" aria-label="Statement">
      <div class="section-inner statement-inner">
        <div data-aos="morph-up" data-aos-duration="1000">
          <p class="statement-outline">THE DEVELOPER<br />BEHIND THE WORK.</p>
        </div>
        <p class="statement-solid" data-aos="fade-up" data-aos-delay="300" data-aos-duration="800">
          Systems that <strong>scale</strong>. Interfaces that <strong>respect the user</strong>. Code that feels <strong>inevitable</strong>.
        </p>
      </div>
    </section>

    <!-- Kudos -->
    <section class="section-panel">
      <span class="outline-text outline-text--right" aria-hidden="true">Kudos</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Kudos</h2>
        <div class="kudos-content">
          <p class="kudos_section-content" data-aos="reveal-left" data-aos-duration="800">
            It's very rare these days to make anything great all on your own. I have only included work that
            I had a large contribution to, but whether it's design, ideas, UX, process, software
            engineering, mentorship, advice, or creative direction, the following people have influenced my
            growth and career path in a massive way:
            <a href="https://www.linkedin.com/in/leoabasjr/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Leopoldo Abas Jr.</a>,
            <a href="https://www.linkedin.com/in/jamesolano/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">James Nelson Olaño</a>,
            <a href="https://www.linkedin.com/in/kevin-juanillo-1835b9b9/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Kevin Juanillo</a>,
            <a href="https://www.linkedin.com/in/marian-rae-alvarado-3057b8190/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Marian Rae Alvarado</a>,
            <a href="https://www.linkedin.com/in/jeremiah-diaz-097556a4/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Jeremiah Diaz</a>,
            <a href="https://www.linkedin.com/in/eric-francis-casaljay-461418150/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Eric Francis Casaljay</a>
            and last but not least
            <a href="https://www.linkedin.com/in/ma-clarizza-folloso-ab418b1aa/" class="kudos_section-link" target="_blank" rel="noopener noreferrer">Ma. Clarizza Folloso</a>.
            THANK YOU.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="section-panel section-panel--alt">
      <span class="outline-text outline-text--left" aria-hidden="true">Contact</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Contact</h2>
        <ContactForm />
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── Scroll progress bar ── */
  const progressBar = document.createElement('div');
  progressBar.className = 'scroll-progress';
  document.body.appendChild(progressBar);

  gsap.to(progressBar, {
    scaleX: 1,
    ease: 'none',
    scrollTrigger: {
      trigger: document.documentElement,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.3,
    },
  });

  /* ── Section reveal animations with GSAP ScrollTrigger ── */
  const sections = gsap.utils.toArray<HTMLElement>('.section-panel');

  sections.forEach((section) => {
    /* Outline text reveal */
    const outline = section.querySelector('.outline-text') as HTMLElement | null;
    if (outline) {
      const isRight = outline.classList.contains('outline-text--right');
      gsap.fromTo(outline,
        { opacity: 0, x: isRight ? 40 : -40 },
        {
          opacity: 1, x: 0, duration: 1, ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        }
      );
    }

    /* Subtle section parallax — shift inner content slightly */
    const inner = section.querySelector('.section-inner') as HTMLElement | null;
    if (inner) {
      gsap.fromTo(inner,
        { y: 40, opacity: 0.8 },
        {
          y: 0, opacity: 1, duration: 1, ease: 'power2.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 90%',
            end: 'top 40%',
            scrub: 0.5,
          },
        }
      );
    }
  });

  /* ── Service tags → scroll to contact ── */
  const msg = document.querySelector('#message') as HTMLTextAreaElement | null;
  document.querySelectorAll('.service-tag').forEach((tag) => {
    (tag as HTMLElement).addEventListener('click', function () {
      document.querySelector('#contact')?.scrollIntoView({ behavior: 'smooth' });
      if (msg) {
        msg.value = (this as HTMLElement).textContent?.trim() + ' ';
        msg.style.color = 'var(--text-primary)';
      }
    });
  });

  /* ── Explore toggle ── */
  document.querySelectorAll('.explore-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const details = (btn as HTMLElement).previousElementSibling as HTMLElement | null;
      if (details?.classList.contains('work-details')) {
        details.classList.toggle('visible');
        (btn as HTMLElement).textContent = details.classList.contains('visible') ? 'Close' : 'Explore';
      }
    });
  });
</script>

<style>
  /* ── About ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  .about-image {
    perspective: 1000px;
  }

  .about-image img {
    width: 100%;
    border-radius: 1rem;
    filter: var(--img-filter);
    transition: filter 0.5s ease, transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform-style: preserve-3d;
  }

  .about-image img:hover {
    filter: var(--img-filter-hover);
    transform: rotateY(-4deg) rotateX(2deg) scale(1.02);
  }

  .about-me_img-mobile {
    display: none;
    margin-bottom: 1.5rem;
  }

  .mobile-portrait {
    width: 100%;
    max-width: 320px;
    border-radius: 0.75rem;
  }

  .about-cta {
    margin-top: 2rem;
  }

  /* ── Services ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .services-bottom {
    display: flex;
    align-items: flex-start;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .services-tags {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .service-tag {
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.5px;
    padding: 0.7rem 1.25rem;
    border: 1px solid var(--services-tag-border);
    border-radius: 2rem;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    white-space: nowrap;
  }

  .service-tag:hover {
    color: #000;
    border-color: var(--color-orange);
    background: var(--color-orange);
  }

  .services-cta {
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 24ch;
    flex-shrink: 0;
  }

  /* ── Works — Employer Card ── */
  .employer-card {
    display: flex;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: flex-start;
    padding: clamp(1.5rem, 3vw, 2.5rem) 0;
    border-bottom: 1px solid var(--border);
  }

  .employer-logo {
    width: 88px;
    height: auto;
    flex-shrink: 0;
    filter: var(--img-filter);
    transition: filter 0.4s ease;
  }

  .employer-card:hover .employer-logo {
    filter: var(--img-filter-hover);
  }

  .employer-text h3 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .employer-text .text-section {
    margin-bottom: 0.75rem;
  }

  /* Work details toggle */
  .work-details {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.3s ease, margin 0.3s ease;
    margin-bottom: 0;
  }

  .work-details.visible {
    max-height: 200px;
    opacity: 1;
    margin-bottom: 0.75rem;
  }

  .work-details ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.5rem 0;
  }

  .work-details ul li {
    font-size: 0.85rem;
    text-transform: lowercase;
    letter-spacing: 0.5px;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    color: var(--text-muted);
  }

  .explore-btn {
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-orange);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: color 0.3s;
  }

  .explore-btn:hover {
    color: var(--text-primary);
  }

  /* Projects — horizontal scroll track */
  .project-track {
    display: flex;
    gap: clamp(1.5rem, 3vw, 2rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 1.5rem;
    margin-inline: calc(-1 * clamp(1.25rem, 5vw, 7.2%));
    padding-inline: clamp(1.25rem, 5vw, 7.2%);
  }

  /* Hide scrollbar but keep functionality */
  .project-track::-webkit-scrollbar {
    height: 4px;
  }
  .project-track::-webkit-scrollbar-track {
    background: transparent;
  }
  .project-track::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }
  .project-track::-webkit-scrollbar-thumb:hover {
    background: var(--color-orange);
  }
  .project-track {
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .project-card {
    flex: 0 0 clamp(320px, 75vw, 520px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: clamp(1rem, 2vw, 1.5rem);
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: var(--glass-bg);
    transition: border-color 0.4s ease, transform 0.4s ease;
  }

  .project-card:hover {
    border-color: var(--color-orange-dim, rgba(255,117,24,0.3));
    transform: translateY(-4px);
  }

  .project-card__image img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 0.75rem;
    filter: var(--img-filter);
    transition: filter 0.5s ease;
  }

  .project-card:hover .project-card__image img {
    filter: var(--img-filter-hover);
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-card__title {
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .project-card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin-top: 0.25rem;
  }

  .project-card__tags li {
    font-size: 0.78rem;
    text-transform: lowercase;
    letter-spacing: 0.5px;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    color: var(--text-muted);
    transition: border-color 0.3s;
  }

  .project-card:hover .project-card__tags li {
    border-color: var(--color-orange-dim, rgba(255,117,24,0.3));
  }

  /* ── thy keycabz — Featured ── */
  .keycabz-section {
    background: var(--section-bg);
  }

