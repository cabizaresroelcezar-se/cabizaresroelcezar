<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── Scroll progress bar ── */
  const progressBar = document.createElement('div');
  progressBar.className = 'scroll-progress';
  document.body.appendChild(progressBar);

  gsap.to(progressBar, {
    scaleX: 1,
    ease: 'none',
    scrollTrigger: {
      trigger: document.documentElement,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.3,
    },
  });

  /* ── Section reveal animations with GSAP ScrollTrigger ── */
  const sections = gsap.utils.toArray<HTMLElement>('.section-panel');

  sections.forEach((section) => {
    const outline = section.querySelector('.outline-text') as HTMLElement | null;
    if (outline) {
      const isRight = outline.classList.contains('outline-text--right');
      gsap.fromTo(outline,
        { opacity: 0, x: isRight ? 40 : -40 },
        {
          opacity: 1, x: 0, duration: 1, ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        }
      );
    }

    /* Section parallax — desktop only */
    if (window.innerWidth > 768) {
      const inner = section.querySelector('.section-inner') as HTMLElement | null;
      if (inner) {
        gsap.fromTo(inner,
          { y: 40, opacity: 0.8 },
          {
            y: 0, opacity: 1, duration: 1, ease: 'power2.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 90%',
              end: 'top 40%',
              scrub: 0.5,
            },
          }
        );
      }
    }
  });

  /* ── Service tags → scroll to contact ── */
  const msg = document.querySelector('#message') as HTMLTextAreaElement | null;
  document.querySelectorAll('.service-tag').forEach((tag) => {
    (tag as HTMLElement).addEventListener('click', function () {
      document.querySelector('#contact')?.scrollIntoView({ behavior: 'smooth' });
      if (msg) {
        msg.value = (this as HTMLElement).textContent?.trim() + ' ';
        msg.style.color = 'var(--text-primary)';
      }
    });
  });

  const isMobile = window.innerWidth <= 768;

  /* Services: scroll-pinned card spotlight (desktop) */
  const serviceSlides = gsap.utils.toArray<HTMLElement>('.service-slide');
  const svcProgressBar = document.querySelector('.services-progress__bar') as HTMLElement | null;
  if (serviceSlides.length && !isMobile) {
    gsap.set(serviceSlides, { opacity: 0.25, scale: 0.95, filter: 'blur(1px)' });
    gsap.set(serviceSlides[0], { opacity: 1, scale: 1, filter: 'blur(0px)' });

    const servicesTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#services',
        start: 'top top',
        end: () => `+=${serviceSlides.length * 60}%`,
        pin: true,
        scrub: 1.2,
        anticipatePin: 0.5,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          if (svcProgressBar) svcProgressBar.style.width = `${self.progress * 100}%`;
        },
      },
    });

    serviceSlides.forEach((slide, i) => {
      if (i > 0) {
        servicesTl.to(serviceSlides[i - 1], { opacity: 0.25, scale: 0.95, filter: 'blur(1px)', duration: 0.5 }, i);
        servicesTl.to(slide, { opacity: 1, scale: 1, filter: 'blur(0px)', duration: 0.5 }, i);
      }
    });
  } else if (serviceSlides.length) {
    gsap.set(serviceSlides, { opacity: 0, y: 40 });
    ScrollTrigger.create({
      trigger: '.services-grid',
      start: 'top 85%',
      onEnter: () => {
        gsap.to(serviceSlides, {
          opacity: 1, y: 0,
          duration: 0.5,
          stagger: 0.08,
          ease: 'power3.out',
        });
      },
      once: true,
    });
  }

  /* Tech stack cards: stagger reveal */
  const stackCards = gsap.utils.toArray<HTMLElement>('.stack-card');
  if (stackCards.length) {
    stackCards.forEach((card) => {
      const chips = gsap.utils.toArray<HTMLElement>('.stack-chip', card);
      gsap.set(chips, { opacity: 0, y: 14, scale: 0.95 });
      ScrollTrigger.create({
        trigger: card,
        start: 'top 85%',
        onEnter: () => {
          gsap.to(chips, {
            opacity: 1, y: 0, scale: 1,
            duration: 0.35,
            stagger: 0.04,
            ease: 'power2.out',
          });
        },
        once: true,
      });
    });
  }

  /* Project cards: stagger reveal per grid */
  const projectSlides = gsap.utils.toArray<HTMLElement>('.project-slide');
  if (projectSlides.length) {
    document.querySelectorAll('.project-grid').forEach((grid) => {
      const cards = gsap.utils.toArray<HTMLElement>('.project-card', grid as HTMLElement);
      if (!cards.length) return;
      gsap.set(cards, { opacity: 0, y: 40, scale: 0.96 });
      ScrollTrigger.create({
        trigger: grid,
        start: 'top 82%',
        onEnter: () => {
          gsap.to(cards, {
            opacity: 1, y: 0, scale: 1,
            duration: 0.6,
            stagger: 0.12,
            ease: 'power3.out',
          });
        },
        once: true,
      });
    });
  }

  /* Kudos: scroll-pinned person spotlight (desktop) */
  const kudosSlides = gsap.utils.toArray<HTMLElement>('.kudos-slide');
  const kudosProgressBar = document.querySelector('.kudos-progress__bar') as HTMLElement | null;
  if (kudosSlides.length && !isMobile) {
    gsap.set(kudosSlides, { opacity: 0.2, scale: 0.95, filter: 'blur(1px)' });
    gsap.set(kudosSlides[0], { opacity: 1, scale: 1, filter: 'blur(0px)' });

    const kudosTl = gsap.timeline({
      scrollTrigger: {
        trigger: '.kudos-pinned',
        start: 'top top',
        end: () => `+=${kudosSlides.length * 50}%`,
        pin: true,
        scrub: 1.2,
        anticipatePin: 0.5,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          if (kudosProgressBar) kudosProgressBar.style.width = `${self.progress * 100}%`;
        },
      },
    });

    kudosSlides.forEach((slide, i) => {
      if (i > 0) {
        kudosTl.to(kudosSlides[i - 1], { opacity: 0.2, scale: 0.95, filter: 'blur(1px)', duration: 0.5 }, i);
        kudosTl.to(slide, { opacity: 1, scale: 1, filter: 'blur(0px)', duration: 0.5 }, i);
      }
    });
  } else if (kudosSlides.length) {
    gsap.set(kudosSlides, { opacity: 0, y: 30 });
    ScrollTrigger.create({
      trigger: '.kudos-grid',
      start: 'top 85%',
      onEnter: () => {
        gsap.to(kudosSlides, {
          opacity: 1, y: 0,
          duration: 0.5,
          stagger: 0.1,
          ease: 'power3.out',
        });
      },
      once: true,
    });
  }

  /* Gentle section entrance — no scrub, just a quick one-time fade */
  const sectionPanels = gsap.utils.toArray<HTMLElement>('.section-panel');
  sectionPanels.forEach((panel) => {
    gsap.set(panel, { opacity: 0, y: 30 });
    ScrollTrigger.create({
      trigger: panel,
      start: 'top 88%',
      onEnter: () => {
        gsap.to(panel, {
          opacity: 1, y: 0,
          duration: 0.6,
          ease: 'power2.out',
        });
      },
      once: true,
    });
  });

  /* Venture cards: slide-in */
  const ventureCards = gsap.utils.toArray<HTMLElement>('.venture-card');
  ventureCards.forEach((card, i) => {
    gsap.set(card, { opacity: 0, x: isMobile ? 0 : (i % 2 === 0 ? -80 : 80), y: isMobile ? 30 : 0 });
    ScrollTrigger.create({
      trigger: card,
      start: 'top 88%',
      onEnter: () => {
        gsap.to(card, {
          opacity: 1, x: 0, y: 0,
          duration: isMobile ? 0.5 : 0.9,
          ease: isMobile ? 'power2.out' : 'back.out(1.4)',
        });
      },
      once: true,
    });
  });

  /* Employer card: clip-path reveal */
  const empCard = document.querySelector('.employer-card') as HTMLElement | null;
  if (empCard) {
    gsap.set(empCard, { clipPath: 'inset(0 100% 0 0)' });
    ScrollTrigger.create({
      trigger: empCard,
      start: 'top 85%',
      onEnter: () => {
        gsap.to(empCard, {
          clipPath: 'inset(0 0% 0 0)',
          duration: isMobile ? 0.7 : 1.2,
          ease: 'power3.inOut',
        });
      },
      once: true,
    });
  }

  /* Statement: zoom reveal */
  const stmtOutline = document.querySelector('.statement-outline') as HTMLElement | null;
  if (stmtOutline) {
    gsap.fromTo(stmtOutline,
      { scale: isMobile ? 1.1 : 1.4, filter: isMobile ? 'blur(4px)' : 'blur(8px)', opacity: 0 },
      {
        scale: 1, filter: 'blur(0px)', opacity: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: '.statement-panel',
          start: 'top 80%',
          end: 'center center',
          scrub: 0.8,
        },
      }
    );
  }

  /* Desktop-only: heavy scroll effects */
  if (!isMobile) {
    /* Logo frames: scroll-driven float & rotation */
    gsap.utils.toArray<HTMLElement>('.keycabz-logo-frame, .cryptobuds-logo-frame, .yobi-logo-frame').forEach((frame, i) => {
      gsap.to(frame, {
        y: -20,
        rotation: (i % 2 === 0 ? 4 : -4),
        ease: 'none',
        scrollTrigger: {
          trigger: frame,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        },
      });
    });

    /* Marquee strip: scroll-speed modulation */
    const marqueeInner = document.querySelector('.marquee-inner') as HTMLElement | null;
    if (marqueeInner) {
      gsap.to(marqueeInner, {
        xPercent: -5,
        ease: 'none',
        scrollTrigger: {
          trigger: '.marquee-strip',
          start: 'top bottom',
          end: 'bottom top',
          scrub: 0.5,
        },
      });
    }

    /* Floating ambient orbs: per-section parallax */
    const orbConfigs = [
      { sel: '#about-me', size: 160, pos: 'right: 10%; top: 15%', dx: 20, dy: -45 },
      { sel: '#about-me', size: 120, pos: 'left: 5%; bottom: 25%', dx: -15, dy: -30 },
      { sel: '#services', size: 180, pos: 'right: 5%; top: 20%', dx: 30, dy: -60 },
      { sel: '#services', size: 130, pos: 'left: 15%; bottom: 15%', dx: -20, dy: -35 },
      { sel: '.keycabz-section', size: 200, pos: 'left: 8%; top: 30%', dx: -25, dy: -50 },
      { sel: '.keycabz-section', size: 140, pos: 'right: 12%; bottom: 20%', dx: 18, dy: -40 },
      { sel: '.cryptobuds-section', size: 160, pos: 'right: 10%; bottom: 25%', dx: 20, dy: -45 },
      { sel: '.cryptobuds-section', size: 120, pos: 'left: 18%; top: 20%', dx: -15, dy: -30 },
      { sel: '.yobi-section', size: 170, pos: 'left: 5%; top: 40%', dx: -30, dy: -55 },
      { sel: '.yobi-section', size: 130, pos: 'right: 8%; bottom: 30%', dx: 22, dy: -35 },
      { sel: '#works', size: 140, pos: 'left: 8%; top: 25%', dx: -18, dy: -40 },
      { sel: '.ventures-section', size: 160, pos: 'left: 12%; bottom: 20%', dx: -20, dy: -50 },
      { sel: '.ventures-section', size: 110, pos: 'right: 6%; top: 18%', dx: 15, dy: -30 },
      { sel: '.statement-panel', size: 220, pos: 'left: 50%; top: 30%', dx: -10, dy: -35 },
      { sel: '#contact', size: 150, pos: 'right: 8%; top: 25%', dx: 25, dy: -45 },
      { sel: '#contact', size: 110, pos: 'left: 10%; bottom: 20%', dx: -12, dy: -28 },
    ];

    orbConfigs.forEach(({ sel, size, pos, dx, dy }) => {
      const parent = document.querySelector(sel) as HTMLElement | null;
      if (!parent) return;
      const orb = document.createElement('div');
      orb.className = 'floating-orb-decor';
      orb.style.cssText = `
        position: absolute; width: ${size}px; height: ${size}px;
        border-radius: 50%;
        background: radial-gradient(circle, var(--color-orange-glow), transparent 70%);
        pointer-events: none; z-index: 0;
        filter: blur(50px); opacity: 0.3;
        ${pos}
      `;
      parent.appendChild(orb);

      gsap.to(orb, {
        y: dy, x: dx,
        ease: 'none',
        scrollTrigger: {
          trigger: parent,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1.5,
        },
      });
    });
  }
