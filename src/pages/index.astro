---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SpatialDock from '../components/SpatialDock.astro';
import SpatialHero from '../components/SpatialHero.astro';
import GlassCard from '../components/GlassCard.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
import ContactForm from '../components/ContactForm.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Roel Cezar Cabizares - Software Engineer & Front-end Developer, UI/UX Enthusiast">
  <Header />
  <SpatialDock />

  <main>
    <!-- Hero (greetings unchanged) -->
    <SpatialHero
      heading="Hi there,"
      subheading="I'm Roel Cezar Cabizares"
      description="I'm a SWE specializing in front-end development, UI/UX, and digital experience."
    />

    <!-- About Me -->
    <section id="about-me" class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">About Me</span>
      <div class="section-inner">
        <h2 class="section-title section-title--hero" data-aos="morph-up" data-aos-duration="800">About Me</h2>
        <div class="about-content">
          <p class="content-paragraph" data-aos="fade-up" data-aos-duration="600">
            Hello, I'm a <strong>software engineer &amp; developer</strong> based in the Philippines, and I conserve an expressive passion for <strong>user interface</strong>, <strong>visual design</strong>, and creating intuitive, dynamic user experiences.
          </p>
          <p class="content-paragraph" data-aos="fade-up" data-aos-duration="600" data-aos-delay="80">
            Given enough coffee and inexhaustible enthusiasm, I am easily inspired and more willing to follow my ideas wherever they take me. I'm a dynamic person, an expressive, talented spirit with an innate ability to entertain and inspire. I'm never satisfied with just coming up with ideas. Instead, I have an almost impulsive need to act on them.
          </p>
          <p class="content-paragraph" data-aos="fade-up" data-aos-duration="600" data-aos-delay="160">
            I'm also experienced in and completed various <strong>responsive website designs</strong>, <strong>front-end assets</strong>, and <strong>custom WordPress builds</strong>.
          </p>
          <p class="about-cta" data-aos="fade-up" data-aos-delay="240">
            <a href="#services" class="content-link">See what I do</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="section-panel section-panel--alt services-pinned">
      <span class="outline-text outline-text--right" aria-hidden="true">Services</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Services</h2>

        <div class="services-grid">
          <div class="service-slide" data-service="0">
            <GlassCard
              icon={`${base}icons/web-development.svg`}
              title="Web Development"
              description="Design and develop user-centric websites and modern interfaces for digital products or services — helping transfer business strengths and visual assets to the web."
              type="web-development"
            />
          </div>
          <div class="service-slide" data-service="1">
            <GlassCard
              icon={`${base}icons/design.svg`}
              title="Branding & Design"
              description="Full strategy design and execution for new and refresh brand projects, including positioning, brand architecture, and identity systems that make a brand feel intentional."
              type="design"
            />
          </div>
          <div class="service-slide" data-service="2">
            <GlassCard
              icon={`${base}icons/digital-marketing.svg`}
              title="Digital Marketing"
              description="Design for new and existing solutions, including UI/UX, visual design, and marketing support accessible to benefit business growth and connect with real people."
              type="digital-marketing"
            />
          </div>
        </div>

        <div class="services-progress">
          <div class="services-progress__bar"></div>
        </div>

        <div class="services-bottom">
          <p class="services-cta">
            Interested in working together?<br />
            Click a service to start a conversation.
          </p>
          <div class="services-tags">
            <button type="button" class="service-tag">Web &amp; Application Development</button>
            <button type="button" class="service-tag">Responsive Web Design</button>
            <button type="button" class="service-tag">Front-End Development</button>
            <button type="button" class="service-tag">Full-Stack Development</button>
            <button type="button" class="service-tag">React &amp; Next.js</button>
            <button type="button" class="service-tag">ASP.NET &amp; Blazor</button>
            <button type="button" class="service-tag">User Experience Design</button>
            <button type="button" class="service-tag">User Interface Design</button>
            <button type="button" class="service-tag">Design Systems</button>
            <button type="button" class="service-tag">Brand Strategy &amp; Identity</button>
            <button type="button" class="service-tag">Digital Experience Optimization</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee Strip -->
    <div class="marquee-strip" aria-hidden="true">
      <div class="marquee-inner">
        <span>DESIGN</span><span class="marquee-dot">·</span>
        <span>CODE</span><span class="marquee-dot">·</span>
        <span>CREATE</span><span class="marquee-dot">·</span>
        <span>INSPIRE</span><span class="marquee-dot">·</span>
        <span>DESIGN</span><span class="marquee-dot">·</span>
        <span>DEVELOP</span><span class="marquee-dot">·</span>
        <span>CREATE</span><span class="marquee-dot">·</span>
        <span>INSPIRE</span><span class="marquee-dot">·</span>
        <span>DESIGN</span><span class="marquee-dot">·</span>
        <span>DEVELOP</span><span class="marquee-dot">·</span>
        <span>CREATE</span><span class="marquee-dot">·</span>
        <span>INSPIRE</span><span class="marquee-dot">·</span>
      </div>
    </div>

    <!-- Tech Stack -->
    <section id="tech-stack" class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">Stack</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Tech Stack</h2>
        <p class="content-paragraph" data-aos="fade-up">Tools and technologies I work with across development, design, and deployment.</p>

        <div class="stack-cards-grid">
        <div class="stack-card" data-aos="fade-up" data-aos-delay="100">
          <h3 class="stack-card__label">Development &amp; Engineering</h3>
          <p class="stack-card__desc">Full-stack web development from backend APIs to frontend interfaces, specializing in .NET ecosystem and modern JavaScript with type safety and scalable architecture.</p>
          <div class="stack-grid">
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/csharp/csharp-original.svg" alt="C#" loading="lazy" /><span>C#</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/dotnetcore/dotnetcore-original.svg" alt="ASP.NET" loading="lazy" /><span>ASP.NET</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/blazor/blazor-original.svg" alt="Blazor" loading="lazy" /><span>Blazor</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg" alt="TypeScript" loading="lazy" /><span>TypeScript</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg" alt="JavaScript" loading="lazy" /><span>JavaScript</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg" alt="HTML5" loading="lazy" /><span>HTML5</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/sass/sass-original.svg" alt="SASS/SCSS" loading="lazy" /><span>SASS/SCSS</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg" alt="Node.js" loading="lazy" /><span>Node.js</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/php/php-original.svg" alt="PHP" loading="lazy" /><span>PHP</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/wordpress/wordpress-plain.svg" alt="WordPress" loading="lazy" /><span>WordPress</span></div>
          </div>
        </div>

        <div class="stack-card" data-aos="fade-up" data-aos-delay="200">
          <h3 class="stack-card__label">Front-End Frameworks</h3>
          <p class="stack-card__desc">Modern component-driven UIs with meta-frameworks, utility-first styling, and optimized build tools for production-grade applications.</p>
          <div class="stack-grid">
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg" alt="React" loading="lazy" /><span>React</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg" alt="Next.js" loading="lazy" class="icon-adaptive" /><span>Next.js</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vuejs/vuejs-original.svg" alt="Vue.js" loading="lazy" /><span>Vue.js</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vitejs/vitejs-original.svg" alt="Vite" loading="lazy" /><span>Vite</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg" alt="Tailwind CSS" loading="lazy" /><span>Tailwind</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg" alt="Astro" loading="lazy" class="icon-adaptive" /><span>Astro</span></div>
          </div>
        </div>

        <div class="stack-card" data-aos="fade-up" data-aos-delay="250">
          <h3 class="stack-card__label">CMS &amp; DXP</h3>
          <p class="stack-card__desc">Enterprise content management and digital experience platforms for scalable publishing workflows.</p>
          <div class="stack-grid">
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/oracle/oracle-original.svg" alt="Oracle CMS" loading="lazy" /><span>Oracle CMS</span></div>
            <div class="stack-chip"><svg viewBox="0 0 149.81 148.48" xmlns="http://www.w3.org/2000/svg" class="stack-chip__svg"><path d="m50.29 81.41v17.69a49.41 49.41 0 0 0 49.35-49.35h-17.64a31.71 31.71 0 0 1 -31.71 31.66z" fill="#3be081"/><path d="m50.29 130.16a31.43 31.43 0 0 1 0-62.85v-17.55a49 49 0 0 0 -.14 98h.14z" fill="#0037ff"/><path d="m50.29 130.16v17.55a49 49 0 0 0 49-49h-17.57a31.46 31.46 0 0 1 -31.43 31.45z" fill="#0cf"/><path d="m50.29 32.19v17.56a49 49 0 0 0 49-49h-17.57a31.46 31.46 0 0 1 -31.43 31.44z" fill="#861dff"/><path d="m99.59 32.19v17.56a49 49 0 0 0 49-49h-17.59a31.46 31.46 0 0 1 -31.41 31.44z" fill="#fc7f10"/></svg><span>Optimizely</span></div>
          </div>
        </div>

        <div class="stack-card" data-aos="fade-up" data-aos-delay="300">
          <h3 class="stack-card__label">Design Tools</h3>
          <p class="stack-card__desc">UI/UX design, wireframing, prototyping, and visual identity systems from concept to handoff across all platforms.</p>
          <div class="stack-grid">
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/figma/figma-original.svg" alt="Figma" loading="lazy" /><span>Figma</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/xd/xd-original.svg" alt="Adobe XD" loading="lazy" /><span>Adobe XD</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/illustrator/illustrator-plain.svg" alt="Illustrator" loading="lazy" class="icon-adaptive" /><span>Illustrator</span></div>
          </div>
        </div>

        <div class="stack-card" data-aos="fade-up" data-aos-delay="350">
          <h3 class="stack-card__label">Cloud, DevOps &amp; Tooling</h3>
          <p class="stack-card__desc">CI/CD pipelines, cloud infrastructure, project management, documentation, databases, and testing frameworks for scalable deployments.</p>
          <div class="stack-grid">
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/github/github-original.svg" alt="GitHub" loading="lazy" class="icon-adaptive" /><span>GitHub</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/gitlab/gitlab-original.svg" alt="GitLab" loading="lazy" /><span>GitLab</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/bitbucket/bitbucket-original.svg" alt="Bitbucket" loading="lazy" /><span>Bitbucket</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/jira/jira-original.svg" alt="Jira" loading="lazy" /><span>Jira</span></div>
            <div class="stack-chip"><img src="https://api.iconify.design/simple-icons/confluence.svg" alt="Confluence" loading="lazy" class="icon-adaptive" /><span>Confluence</span></div>
            <!-- <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg" alt="MySQL" loading="lazy" /><span>MySQL</span></div> -->
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/azure/azure-original.svg" alt="Azure" loading="lazy" /><span>Azure</span></div>
            <div class="stack-chip"><img src="https://api.iconify.design/simple-icons/supabase.svg" alt="Supabase" loading="lazy" class="icon-adaptive" /><span>Supabase</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/selenium/selenium-original.svg" alt="Selenium" loading="lazy" /><span>Selenium</span></div>
            <div class="stack-chip"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/swagger/swagger-original.svg" alt="Swagger" loading="lazy" /><span>Swagger</span></div>
          </div>
        </div>

        <div class="stack-card" data-aos="fade-up" data-aos-delay="400">
          <h3 class="stack-card__label">Agentic AI</h3>
          <p class="stack-card__desc">AI-assisted development, code generation, prompt engineering, and intelligent automation workflows.</p>
          <div class="stack-grid">
            <div class="stack-chip"><img src="https://api.iconify.design/simple-icons/openai.svg" alt="ChatGPT" loading="lazy" class="icon-adaptive" /><span>ChatGPT</span></div>
            <div class="stack-chip"><img src="https://cdn.simpleicons.org/claude/D97757" alt="Claude" loading="lazy" /><span>Claude</span></div>
            <div class="stack-chip"><img src="https://cdn.simpleicons.org/githubcopilot" alt="GitHub Copilot" loading="lazy" class="icon-adaptive" /><span>GitHub Copilot</span></div>
            <div class="stack-chip"><img src="https://cdn.simpleicons.org/googlegemini/8E75B2" alt="Gemini" loading="lazy" /><span>Gemini</span></div>
          </div>
        </div>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section id="works" class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">Office</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Currently at</h2>

        <!-- Current employer -->
        <article class="employer-card">
          <div class="employer-card__header">
            <div class="employer-card__title">
              <h3><a href="https://www.agiletechops.com/" target="_blank" rel="noopener noreferrer" class="employer-name-link">Agile Tech Ops Inc.</a></h3>
              <span class="employer-period">2025 &ndash; Present &middot; Makati, Philippines</span>
            </div>
          </div>
          <div class="employer-card__body">
            <p class="employer-pos">Full Stack Developer &middot; <em>.NET &amp; Blazor</em></p>
            <p class="employer-role">Building and maintaining full-stack <strong>.NET and Blazor applications</strong> for a U.S.-based client &mdash; shipping fixes, enhancements, and performance improvements while leveraging AI-assisted development tools.</p>
          </div>
        </article>

        <p data-aos="fade-up" class="works-cta">
          Open to new opportunities or collaborations? Feel free to
          <a href="#contact" class="content-link">reach out.</a>
        </p>
      </div>
    </section>

    <!-- Branding CTA ──────────────────────── -->
    <section class="section-panel section-panel--alt branding-cta-section">
      <div class="section-inner branding-cta-inner">
        <div class="branding-cta-content" data-aos="fade-up">
          <p class="keycabz-label">Personal Branding</p>
          <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">The Brand Behind the Work</h2>
          <p class="content-paragraph" data-aos="fade-up" data-aos-delay="100">
            Every element of my identity — from the <strong>logo construction</strong> and <strong>typography</strong> to the 
            <strong>color palette</strong> — is designed with intention. Explore the full case study behind my personal branding.
          </p>
          <a href={`${base}branding`} class="branding-cta-btn" data-aos="fade-up" data-aos-delay="200">
            View Branding &amp; Logo Study
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="branding-cta-visual" data-aos="scale-in" data-aos-duration="900">
          <div class="branding-cta-logo-frame">
            <img src={`${base}logo.png`} alt="CABZ logo" loading="lazy" class="logo-dark" />
            <img src={`${base}logo_light.png`} alt="CABZ logo" loading="lazy" class="logo-light" />
          </div>
        </div>
      </div>
    </section>

    <!-- Ventures ──────────────────────── -->
    <section class="section-panel ventures-section">
      <span class="outline-text outline-text--right" aria-hidden="true">Ventures</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="700">Ventures</h2>
        <p data-aos="fade-up">Personal businesses I co-own and operate — side ventures built from scratch with people I trust.</p>

        <div class="ventures-grid">
          <article class="venture-card">
            <a href="https://www.facebook.com/mesaysillaco.ph" target="_blank" rel="noopener noreferrer" class="venture-card__logo">
              <img src={`${base}mesa-y-silla.png`} alt="Mesa y Silla Co." loading="lazy" />
            </a>
            <div class="venture-card__body">
              <h3><a href="https://www.facebook.com/mesaysillaco.ph" target="_blank" rel="noopener noreferrer" class="venture-name-link">Mesa y Silla Co.</a></h3>
              <p>A tables &amp; chairs rental service catering to events, gatherings, and special occasions — providing reliable logistics and setup so hosts can focus on what matters.</p>
            </div>
          </article>

          <article class="venture-card">
            <a href="https://www.facebook.com/25hype.sneakers" target="_blank" rel="noopener noreferrer" class="venture-card__logo">
              <img src={`${base}25-hype.png`} alt="25HYPE Sneakers" loading="lazy" />
            </a>
            <div class="venture-card__body">
              <h3><a href="https://www.facebook.com/25hype.sneakers" target="_blank" rel="noopener noreferrer" class="venture-name-link">25HYPE Sneakers</a></h3>
              <p>Curated sneaker drops sourcing top-batch UA pairs — built for the culture and the community that lives and breathes footwear.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="section-panel section-panel--alt projects-section">
      <span class="outline-text outline-text--right" aria-hidden="true">Projects</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="700">Projects</h2>
        <p class="text-section project_section-subtitle" data-aos="fade-up">
          A collection of work I've shipped — from development and WordPress builds to brand identities. Mostly a trip down memory lane, with more to come.
        </p>

        <h3 class="project-group-label" data-aos="fade-up">Development</h3>
        <div class="project-grid">
          <article class="project-card project-slide" data-project="0">
            <a href="https://pilasports.com/" target="_blank" rel="noopener noreferrer" class="project-card__image">
              <img src={`${base}pila.png`} alt="PILA" loading="lazy" />
            </a>
            <div class="project-card__body">
              <h3><a href="https://pilasports.com/" target="_blank" rel="noopener noreferrer" class="project-name-link">Player Invite & League Arranger - PILA Sports</a></h3>
              <ul class="project-breakdown">
                <li><strong>Challenge</strong> Build a league management platform for pickleball from scratch — no existing brand, no UI framework.</li>
                <li><strong>Design</strong> Created wireframes and prototypes in Figma, mapping out player registration flows, league brackets, and a scheduling interface.</li>
                <li><strong>Engineering</strong> Developed the full front-end with a focus on responsive layouts and real-time data presentation for match results and standings.</li>
              </ul>
            </div>
          </article>

          <article class="project-card project-slide" data-project="1">
            <a href="https://www.facebook.com/rescue8tradingphils" target="_blank" rel="noopener noreferrer" class="project-card__image">
              <img src={`${base}rescue-8.jpg`} alt="Rescue 8 Trading Philippines, Inc." loading="lazy" />
            </a>
            <div class="project-card__body">
              <h3><a href="https://www.facebook.com/rescue8tradingphils" target="_blank" rel="noopener noreferrer" class="project-name-link">Rescue 8 Trading</a></h3>
              <ul class="project-breakdown">
                <li><strong>Challenge</strong> Deliver a product catalog and e-commerce site for a fire safety and industrial equipment supplier with limited digital presence.</li>
                <li><strong>Design</strong> Structured the information architecture around product categories and trust signals — mockups built in Figma.</li>
                <li><strong>Engineering</strong> Custom WordPress template with WooCommerce integration, optimized for product browsing and mobile checkout flow.</li>
              </ul>
            </div>
          </article>

          <article class="project-card project-slide" data-project="2">
            <a href="https://www.facebook.com/rideslowlifestyle" target="_blank" rel="noopener noreferrer" class="project-card__image">
              <img src={`${base}ride-slow.jpg`} alt="Ride Slow Lifestyle" loading="lazy" />
            </a>
            <div class="project-card__body">
              <h3><a href="https://www.facebook.com/rideslowlifestyle" target="_blank" rel="noopener noreferrer" class="project-name-link">Ride Slow Lifestyle</a></h3>
              <ul class="project-breakdown">
                <li><strong>Challenge</strong> A lifestyle cycling brand needed an online storefront that matched its visual-heavy social media presence.</li>
                <li><strong>Design</strong> Designed gallery-first layouts and a visual product grid rooted in the brand's street and cycling aesthetic.</li>
                <li><strong>Engineering</strong> WordPress with WooCommerce, integrated Messenger chat widget, and a lightweight gallery plugin for showcasing rides and events.</li>
              </ul>
            </div>
          </article>
        </div>

        <h3 class="project-group-label" data-aos="fade-up">Branding</h3>
        <div class="project-grid">
          <article class="project-card project-slide" data-project="3">
            <a href="https://www.facebook.com/kademyahanfoodhouse/" target="_blank" rel="noopener noreferrer" class="project-card__image">
              <img src={`${base}kademyahan.png`} alt="Kademyahan Food House" loading="lazy" />
            </a>
