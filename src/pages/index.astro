---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SpatialDock from '../components/SpatialDock.astro';
import SpatialHero from '../components/SpatialHero.astro';
import GlassCard from '../components/GlassCard.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
import ContactForm from '../components/ContactForm.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Roel Cezar Cabizares - Front-end Developer & Designer">
  <Header />
  <SpatialDock />

  <main>
    <!-- Hero (greetings unchanged) -->
    <SpatialHero
      heading="Hi there,"
      subheading="I'm Roel Cezar Cabizares"
      description="I'm a SWE specializing in front-end development, UI/UX, and digital experience."
    />

    <!-- About Me -->
    <section id="about-me" class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">About Me</span>
      <div class="section-inner">
        <h2 class="section-title section-title--hero" data-aos="morph-up" data-aos-duration="800">About Me</h2>
        <div class="about-content">
          <p class="content-paragraph content-paragraph--lead" data-aos="reveal-left" data-aos-duration="700">
            Hello, I'm a <strong>software engineer &amp; developer</strong> based in the Philippines, and I conserve an expressive passion for <strong>user interface</strong>, <strong>visual design</strong>, and creating intuitive, dynamic user experiences.
          </p>
          <p class="content-paragraph" data-aos="reveal-left" data-aos-duration="700" data-aos-delay="100">
            Given enough coffee and inexhaustible enthusiasm, I am easily inspired and more willing to follow my ideas wherever they take me. I'm a dynamic person, an expressive, talented spirit with an innate ability to entertain and inspire. I'm never satisfied with just coming up with ideas. Instead, I have an almost impulsive need to act on them.
          </p>
          <p class="content-paragraph" data-aos="reveal-left" data-aos-duration="700" data-aos-delay="200">
            I'm also experienced in and completed various <strong>responsive website designs</strong>, <strong>front-end assets</strong>, and <strong>custom WordPress builds</strong>.
          </p>
          <p class="about-cta" data-aos="fade-up" data-aos-delay="300">
            <a href="#services" class="content-link">See what I do</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="section-panel section-panel--alt">
      <span class="outline-text outline-text--right" aria-hidden="true">Services</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Services</h2>

        <div class="services-grid">
          <GlassCard
            icon={`${base}icons/web-development.svg`}
            title="Web Development"
            description="Design and develop user-centric websites and modern interfaces for digital products or services — helping transfer business strengths and visual assets to the web."
            type="web-development"
          />
          <GlassCard
            icon={`${base}icons/design.svg`}
            title="Branding & Design"
            description="Full strategy design and execution for new and refresh brand projects, including positioning, brand architecture, and identity systems that make a brand feel intentional."
            type="design"
          />
          <GlassCard
            icon={`${base}icons/digital-marketing.svg`}
            title="Digital Marketing"
            description="Design for new and existing solutions, including UI/UX, visual design, and marketing support accessible to benefit business growth and connect with real people."
            type="digital-marketing"
          />
        </div>

        <div class="services-bottom" data-aos="fade-up" data-aos-delay="200">
          <div class="services-tags">
            <button type="button" class="service-tag">Website Design</button>
            <button type="button" class="service-tag">Website Development</button>
            <button type="button" class="service-tag">User Experience Interaction</button>
            <button type="button" class="service-tag">User Interface Design</button>
            <button type="button" class="service-tag">Figma Wireframes</button>
            <button type="button" class="service-tag">Figma Low-fidelity Prototypes</button>
            <button type="button" class="service-tag">Visual &amp; Identity Design</button>
            <button type="button" class="service-tag">Visual Layout Design</button>
            <button type="button" class="service-tag">WordPress Website Design</button>
            <button type="button" class="service-tag">WordPress Custom Code</button>
          </div>
          <p class="services-cta">
            Interested in working together?<br />
            Click a service to start a conversation.
          </p>
        </div>
      </div>
    </section>

    <!-- Marquee Strip -->
    <div class="marquee-strip" aria-hidden="true">
      <div class="marquee-inner">
        <span>DESIGN</span><span class="marquee-dot">·</span>
        <span>CODE</span><span class="marquee-dot">·</span>
        <span>CREATE</span><span class="marquee-dot">·</span>
        <span>INSPIRE</span><span class="marquee-dot">·</span>
        <span>DESIGN</span><span class="marquee-dot">·</span>
        <span>DEVELOP</span><span class="marquee-dot">·</span>
        <span>CREATE</span><span class="marquee-dot">·</span>
        <span>INSPIRE</span><span class="marquee-dot">·</span>
        <span>DESIGN</span><span class="marquee-dot">·</span>
        <span>DEVELOP</span><span class="marquee-dot">·</span>
        <span>CREATE</span><span class="marquee-dot">·</span>
        <span>INSPIRE</span><span class="marquee-dot">·</span>
      </div>
    </div>

    <!-- Experience -->
    <section id="works" class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">Office</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Currently at</h2>

        <!-- Current employer -->
        <article class="employer-card">
          <div class="employer-card__header">
            <div class="employer-card__title">
              <h3><a href="https://www.agiletechops.com/" target="_blank" rel="noopener noreferrer" class="employer-name-link">Agile Tech Ops Inc.</a></h3>
              <span class="employer-period">2025 &ndash; Present &middot; Makati, Philippines</span>
            </div>
          </div>
          <div class="employer-card__body">
            <p class="employer-pos">Full Stack Developer &middot; <em>.NET &amp; Blazor</em></p>
            <p class="employer-role">Building and maintaining full-stack <strong>.NET and Blazor applications</strong> for a U.S.-based client &mdash; shipping fixes, enhancements, and performance improvements while leveraging AI-assisted development tools.</p>
          </div>
        </article>

        <p data-aos="fade-up" class="works-cta">
          Open to new opportunities or collaborations? Feel free to
          <a href="#contact" class="content-link">reach out.</a>
        </p>
      </div>
    </section>

    <!-- Branding CTA ──────────────────────── -->
    <section class="section-panel section-panel--alt branding-cta-section">
      <div class="section-inner branding-cta-inner">
        <div class="branding-cta-content" data-aos="fade-up">
          <p class="keycabz-label">Personal Branding</p>
          <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">The Brand Behind the Work</h2>
          <p class="content-paragraph" data-aos="fade-up" data-aos-delay="100">
            Every element of my identity — from the <strong>logo construction</strong> and <strong>typography</strong> to the 
            <strong>color palette</strong> — is designed with intention. Explore the full case study behind my personal branding.
          </p>
          <a href={`${base}branding`} class="branding-cta-btn" data-aos="fade-up" data-aos-delay="200">
            View Branding &amp; Logo Study
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="branding-cta-visual" data-aos="scale-in" data-aos-duration="900">
          <div class="branding-cta-logo-frame">
            <img src={`${base}logo.png`} alt="CABZ logo" loading="lazy" class="logo-dark" />
            <img src={`${base}logo_light.png`} alt="CABZ logo" loading="lazy" class="logo-light" />
          </div>
        </div>
      </div>
    </section>

    <!-- Ventures ──────────────────────── -->
    <section class="section-panel ventures-section">
      <span class="outline-text outline-text--right" aria-hidden="true">Ventures</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="700">Ventures</h2>
        <p data-aos="fade-up">Personal businesses I co-own and operate — side ventures built from scratch with people I trust.</p>

        <div class="ventures-grid">
          <article class="venture-card">
            <a href="https://www.facebook.com/mesaysillaco.ph" target="_blank" rel="noopener noreferrer" class="venture-card__logo">
              <img src={`${base}mesa-y-silla.png`} alt="Mesa y Silla Co." loading="lazy" />
            </a>
            <div class="venture-card__body">
              <h3><a href="https://www.facebook.com/mesaysillaco.ph" target="_blank" rel="noopener noreferrer" class="venture-name-link">Mesa y Silla Co.</a></h3>
              <p>A tables &amp; chairs rental service catering to events, gatherings, and special occasions — providing reliable logistics and setup so hosts can focus on what matters.</p>
            </div>
          </article>

          <article class="venture-card">
            <a href="https://www.facebook.com/25hype.sneakers" target="_blank" rel="noopener noreferrer" class="venture-card__logo">
              <img src={`${base}25-hype.png`} alt="25HYPE Sneakers" loading="lazy" />
            </a>
            <div class="venture-card__body">
              <h3><a href="https://www.facebook.com/25hype.sneakers" target="_blank" rel="noopener noreferrer" class="venture-name-link">25HYPE Sneakers</a></h3>
