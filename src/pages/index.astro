        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="section-panel section-panel--alt">
      <span class="outline-text outline-text--right" aria-hidden="true">Projects</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="700">Projects</h2>
        <p class="text-section project_section-subtitle" data-aos="fade-up">
