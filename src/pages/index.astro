      <span class="outline-text outline-text--right" aria-hidden="true">Cryptobuds</span>
      <div class="section-inner">
        <div class="cryptobuds-hero">
          <div class="cryptobuds-visual" data-aos="scale-in" data-aos-duration="900">
            <a href="https://www.facebook.com/CryptobudsNFT" target="_blank" rel="noopener noreferrer" class="cryptobuds-logo-frame">
              <img src={`${base}cryptobuds.png`} alt="Cryptobuds" loading="lazy" />
