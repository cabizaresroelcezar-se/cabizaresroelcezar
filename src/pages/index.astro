  }

  .kudos-card__name {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-orange);
    text-decoration: none;
    transition: opacity 0.3s;
    line-height: 1.3;
  }

  .kudos-card__name:hover {
    opacity: 0.7;
  }

  .kudos-card__note {
    font-size: var(--fs-sm);
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .kudos-progress {
    width: 100%;
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    margin-top: 2rem;
    overflow: hidden;
  }

  .kudos-progress__bar {
    height: 100%;
    width: 0%;
    background: var(--color-orange);
    border-radius: 2px;
    transition: width 0.1s linear;
  }

  @media (max-width: 1024px) {
    .kudos-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 1rem;
      padding-bottom: 1rem;
      scrollbar-width: none;
    }
    .kudos-grid::-webkit-scrollbar {
      display: none;
    }
    .kudos-card {
      flex: 0 0 80vw;
      max-width: 320px;
      scroll-snap-align: start;
    }
  }

  @media (max-width: 600px) {
    .kudos-card {
      flex: 0 0 85vw;
      max-width: none;
    }
  }

  /* ── Kudos → Contact Bridge ── */
  .section-bridge {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 3rem var(--section-px, 2rem);
    max-width: var(--section-max, 1280px);
    margin: 0 auto;
  }
  .section-bridge__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-orange, #ff7518) 50%, transparent);
    opacity: 0.35;
  }
  .section-bridge__label {
    font-size: var(--fs-sm, 0.875rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-orange, #ff7518);
    opacity: 0.7;
    white-space: nowrap;
  }

  /* ── Section Title Hero Variant ── */
  .section-title--hero {
    font-size: clamp(2rem, 4vw, 3.5rem);
    letter-spacing: -0.03em;
  }

  /* ── Yo-Bi ── */
  .yobi-hero {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .yobi-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .yobi-logo-frame {
    width: clamp(160px, 18vw, 280px);
    height: clamp(160px, 18vw, 280px);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2rem;
    background: var(--glass-bg);
    border: 1px solid var(--color-orange-dim, rgba(255,117,24,0.25));
    box-shadow: 0 0 80px var(--color-orange-glow, rgba(255,117,24,0.1)),
                inset 0 0 0 1px rgba(255,255,255,0.04);
    padding: 2.5rem;
    transition: box-shadow 0.5s ease, transform 0.5s ease;
  }

  .yobi-logo-frame:hover {
    box-shadow: 0 0 120px rgba(255,117,24,0.2),
                inset 0 0 0 1px rgba(255,117,24,0.15);
    transform: scale(1.03);
  }

  .yobi-logo-frame img {
    width: 100%;
    height: auto;
    filter: var(--img-filter);
    transition: filter 0.5s ease;
  }

  .yobi-logo-frame:hover img {
    filter: var(--img-filter-hover);
  }

  .yobi-spotify {
    margin-top: clamp(2rem, 4vw, 3.5rem);
    max-width: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-orange-dim, rgba(255,117,24,0.25));
    background: var(--glass-bg);
    box-shadow: 0 0 40px var(--color-orange-glow, rgba(255,117,24,0.06));
  }

  /* ── Spotify: light mode adaptation ── */
  :global([data-theme="light"]) .yobi-spotify {
    border-color: rgba(0,0,0,0.10);
    background: rgba(255,255,255,0.6);
  }

  :global([data-theme="light"]) .yobi-spotify iframe {
    filter: invert(1) hue-rotate(180deg);
    border-radius: 12px;
  }

  /* ── Marquee Strip ── */
  .marquee-strip {
    overflow: hidden;
    padding: 1.5rem 0;
    background: var(--section-bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .marquee-inner {
    display: inline-flex;
    gap: 2rem;
    animation: marquee-scroll 20s linear infinite;
    will-change: transform;
  }

  .marquee-inner span {
    font-size: clamp(1.5rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: 1px var(--outline-stroke);
    text-stroke: 1px var(--outline-stroke);
    user-select: none;
    flex-shrink: 0;
    transition: color 0.3s ease, -webkit-text-stroke-color 0.3s ease;
  }

  .marquee-inner span:not(.marquee-dot):hover {
    color: var(--color-orange);
    -webkit-text-stroke-color: var(--color-orange);
  }

  .marquee-dot {
    color: var(--color-orange) !important;
    -webkit-text-stroke: none !important;
    opacity: 0.5;
  }

  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Floating Orb Decoration ── */
  .floating-orb-decor {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Branding CTA ── */
  .branding-cta-inner {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .branding-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: inherit;
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 2rem;
    background: transparent;
    color: var(--color-orange);
    border: 2px solid var(--color-orange);
    border-radius: 2rem;
    transition: all 0.3s ease;
    width: fit-content;
    margin-top: 1.5rem;
  }

  .branding-cta-btn:hover {
    background: var(--color-orange);
    color: #000;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px var(--color-orange-glow);
  }

  .branding-cta-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .branding-cta-logo-frame {
    width: clamp(140px, 16vw, 220px);
    height: clamp(140px, 16vw, 220px);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2rem;
    background: var(--glass-bg);
    border: 1px solid var(--color-orange-dim, rgba(255,117,24,0.25));
    box-shadow: 0 0 80px var(--color-orange-glow, rgba(255,117,24,0.1)),
                inset 0 0 0 1px rgba(255,255,255,0.04);
    padding: 2rem;
    transition: box-shadow 0.5s ease, transform 0.5s ease;
  }

  .branding-cta-logo-frame:hover {
    box-shadow: 0 0 120px rgba(255,117,24,0.2),
                inset 0 0 0 1px rgba(255,117,24,0.15);
    transform: scale(1.03);
  }

  .branding-cta-logo-frame img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .branding-cta-logo-frame .logo-light { display: none; }
  .branding-cta-logo-frame .logo-dark { display: block; }
  :global([data-theme="light"]) .branding-cta-logo-frame .logo-dark { display: none; }
  :global([data-theme="light"]) .branding-cta-logo-frame .logo-light { display: block; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .services-bottom {
      flex-direction: column;
    }

    .services-cta {
      max-width: 100%;
    }

    .employer-card {
      flex-direction: column;
      padding: 1.25rem 1.25rem;
      gap: 1rem;
    }

    .employer-logo {
      width: 64px;
    }

    .project-slide {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .keycabz-hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .keycabz-visual {
      order: -1;
    }

    .keycabz-logo-frame {
      width: 160px;
      height: 160px;
      padding: 1.5rem;
    }

    .cryptobuds-hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .cryptobuds-visual {
      order: -1;
    }

    .cryptobuds-logo-frame {
      width: 140px;
      height: 140px;
      padding: 1.5rem;
    }

    .yobi-hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .yobi-visual {
      order: -1;
    }

    .yobi-logo-frame {
      width: 160px;
      height: 160px;
      padding: 1.5rem;
    }

    .venture-card__logo {
      width: 100px;
      height: 100px;
    }

    .venture-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.5rem 1.25rem;
      gap: 1.25rem;
    }

    .branding-cta-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .branding-cta-visual {
      order: -1;
    }

    .branding-cta-logo-frame {
      width: 140px;
      height: 140px;
      padding: 1.5rem;
    }

    .branding-cta-btn {
      margin-inline: auto;
    }
  }

  /* ── iPad / Tablet (769px–1024px) ── */
  @media (min-width: 769px) and (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    .employer-card {
      padding: 1.75rem 2rem;
    }

    .stack-card {
      padding: 1.375rem 1.75rem;
    }

    .project-card__image img {
      height: 120px;
    }

    .keycabz-hero {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
    }

    .cryptobuds-hero {
      grid-template-columns: 0.5fr 1.5fr;
      gap: 3rem;
    }

    .yobi-hero {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
    }

    .ventures-grid {
      gap: 1.25rem;
    }

    .venture-card {
      padding: 2rem 2.25rem;
      gap: 2rem;
    }
  }
