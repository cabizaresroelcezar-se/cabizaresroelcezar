---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SpatialDock from '../components/SpatialDock.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Personal Branding & Logo Study — Roel Cezar Cabizares"
  description="A deep dive into the personal branding and logo study of Roel Cezar Cabizares — covering visual identity, logo construction, typography, and design rationale."
>
  <Header />
  <SpatialDock />

  <main>
    <!-- Hero -->
    <section class="brand-hero">
      <div class="brand-hero__bg">
        <div class="hero-shape-brand"></div>
        <div class="ambient-grid"></div>
      </div>
      <div class="brand-hero__content">
        <p class="brand-label" data-aos="fade-up">Personal Branding &amp; Logo Study</p>
        <h1 class="brand-title" data-aos="morph-up" data-aos-duration="900">
          Cabizares,<br />Roel Cezar
        </h1>
        <p class="brand-desc" data-aos="fade-up" data-aos-delay="200">
          A complete visual identity exploration — from logo construction and typography to design rationale. 
          Every element is intentional, rooted in who I am and what I do.
        </p>
        <div class="brand-meta" data-aos="fade-up" data-aos-delay="300">
          <span class="meta-tag">Visual Identity</span>
          <span class="meta-tag">Logo Design</span>
          <span class="meta-tag">Branding</span>
          <span class="meta-tag">Illustration</span>
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="section-panel section-panel--alt">
      <span class="outline-text outline-text--right" aria-hidden="true">Overview</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">The Brief</h2>
        <div class="brand-overview">
          <div class="overview-block" data-aos="reveal-left" data-aos-duration="700">
            <h3>Objective</h3>
            <p>
              Build a personal brand identity from the ground up — one that reflects my dual nature as a 
              <strong>software engineer</strong> and <strong>visual designer</strong>. The system needed to 
              feel modern, intentional, and adaptable across digital and print applications.
            </p>
          </div>
          <div class="overview-block" data-aos="reveal-left" data-aos-duration="700" data-aos-delay="100">
            <h3>Tools Used</h3>
            <div class="tools-grid">
              <div class="tool-item">
                <span class="tool-icon">Ai</span>
                <span>Adobe Illustrator</span>
              </div>
              <div class="tool-item">
                <span class="tool-icon">Ps</span>
                <span>Adobe Photoshop</span>
              </div>
            </div>
          </div>
          <div class="overview-block" data-aos="reveal-left" data-aos-duration="700" data-aos-delay="200">
            <h3>Scope</h3>
            <p>
              Logo design &amp; construction, typography selection, color palette, brand guidelines, 
              and visual language for digital applications.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Logo Construction -->
    <section class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">Logo</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Logo Construction</h2>
        <p class="section-subtitle" data-aos="fade-up">
          The mark is built from geometric fundamentals — every curve, angle, and proportion 
          is derived from a structured grid system. Nothing is arbitrary.
        </p>

        <div class="logo-showcase" data-aos="scale-in" data-aos-duration="900">
          <div class="logo-display logo-display--dark">
            <img src={`${base}logo.png`} alt="Logo — dark version" loading="lazy" />
            <span class="logo-variant-label">Dark Background</span>
          </div>
          <div class="logo-display logo-display--light">
            <img src={`${base}logo_light.png`} alt="Logo — light version" loading="lazy" />
            <span class="logo-variant-label">Light Background</span>
          </div>
        </div>

        <div class="logo-principles">
          <div class="principle" data-aos="fade-up">
            <div class="principle-num">01</div>
            <h3>Geometric Precision</h3>
            <p>Every curve follows a calculated radius. The letterforms sit on a baseline grid, maintaining optical balance across all sizes.</p>
          </div>
          <div class="principle" data-aos="fade-up" data-aos-delay="100">
            <div class="principle-num">02</div>
            <h3>Scalability</h3>
            <p>Designed to hold clarity from favicon-size to billboard scale. No detail is lost at any resolution — crispness is built in.</p>
          </div>
          <div class="principle" data-aos="fade-up" data-aos-delay="200">
            <div class="principle-num">03</div>
            <h3>Dual Identity</h3>
            <p>The mark carries both technical precision and creative warmth — reflecting the intersection of engineering and design.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Logo Meaning -->
    <section class="section-panel section-panel--alt">
      <span class="outline-text outline-text--right" aria-hidden="true">CABZ</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">The Mark &mdash; C.A.B.Z</h2>
        <p class="section-subtitle" data-aos="fade-up">
          The logo is built from the HTML self-closing tag <code>&lt;/&gt;</code> — a nod to the code that powers everything.
          Each letter of <strong>CABZ</strong> is embedded within that symbol, fusing identity with craft.
        </p>

        <div class="cabz-grid">
          <div class="cabz-letter" data-aos="fade-up">
            <div class="cabz-visual">
              <span class="cabz-tag cabz-tag--open">&lt;</span>
              <span class="cabz-char">c &nbsp</span>
              <span class="cabz-tag cabz-tag--slash">/</span>
              <span class="cabz-tag cabz-tag--close">&gt;</span>
            </div>
            <h3>Letter C</h3>
            <p>Represents the creative foundation — the eye for design, composition, and visual storytelling that drives every project.</p>
          </div>
          <div class="cabz-letter" data-aos="fade-up" data-aos-delay="100">
            <div class="cabz-visual">
              <span class="cabz-tag cabz-tag--open">&lt;</span>
              <span class="cabz-char">a &nbsp</span>
              <span class="cabz-tag cabz-tag--slash">/</span>
              <span class="cabz-tag cabz-tag--close">&gt;</span>
            </div>
            <h3>Letter A</h3>
            <p>Reflects versatility and adaptability — the ability to move across disciplines, tools, and industries.</p>
          </div>
          <div class="cabz-letter" data-aos="fade-up" data-aos-delay="200">
            <div class="cabz-visual">
              <span class="cabz-tag cabz-tag--open">&lt;</span>
              <span class="cabz-char">b &nbsp</span>
              <span class="cabz-tag cabz-tag--slash">/</span>
              <span class="cabz-tag cabz-tag--close">&gt;</span>
            </div>
            <h3>Letter B</h3>
            <p>Embodies the engineering mindset — building systems, writing code, and constructing digital products.</p>
          </div>
          <div class="cabz-letter" data-aos="fade-up" data-aos-delay="300">
            <div class="cabz-visual">
              <span class="cabz-tag cabz-tag--open">&lt;</span>
              <span class="cabz-char">z &nbsp</span>
              <span class="cabz-tag cabz-tag--slash">/</span>
              <span class="cabz-tag cabz-tag--close">&gt;</span>
            </div>
            <h3>Letter Z</h3>
            <p>Symbolizes the drive to create from nothing — taking ideas from zero to launch.</p>
          </div>
        </div>

        <div class="cabz-combined" data-aos="zoom-in" data-aos-delay="400">
          <div class="cabz-visual cabz-visual--combined">
            <span class="cabz-tag cabz-tag--open">&lt;</span>
            <span class="cabz-char">/</span>
            <span class="cabz-tag cabz-tag--close">&gt;</span>
          </div>
          <p class="cabz-combined-label">HTML Self Closing Tag</p>
        </div>
      </div>
    </section>

    <!-- Typography -->
    <section class="section-panel">
      <span class="outline-text outline-text--left" aria-hidden="true">Type</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Typography</h2>
        <p class="section-subtitle" data-aos="fade-up">
          Type is the voice of the brand. A modern geometric sans-serif anchors the system — 
          clean enough for interfaces, expressive enough for headlines.
        </p>

        <div class="type-specimen" data-aos="fade-up" data-aos-delay="100">
          <div class="type-sample type-sample--display">
            <span class="type-weight-label">Light 300</span>
            <p class="type-preview" style="font-weight: 300;">Aa Bb Cc Dd Ee Ff Gg Hh Ii</p>
          </div>
          <div class="type-sample type-sample--body">
            <span class="type-weight-label">Medium 500</span>
            <p class="type-preview" style="font-weight: 500;">Aa Bb Cc Dd Ee Ff Gg Hh Ii</p>
          </div>
          <div class="type-sample type-sample--bold">
            <span class="type-weight-label">Bold 700</span>
            <p class="type-preview" style="font-weight: 700;">Aa Bb Cc Dd Ee Ff Gg Hh Ii</p>
          </div>
        </div>

        <div class="type-scale-demo" data-aos="fade-up" data-aos-delay="200">
          <p class="scale-item" style="font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; letter-spacing: -0.03em;">Hero</p>
          <p class="scale-item" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700;">Heading XL</p>
          <p class="scale-item" style="font-size: clamp(1.25rem, 2vw, 1.5rem); font-weight: 600;">Heading Large</p>
          <p class="scale-item" style="font-size: 1.125rem; font-weight: 500;">Body — 18px base</p>
          <p class="scale-item" style="font-size: 0.9rem; font-weight: 400; color: var(--text-secondary);">Caption — 14.4px</p>
          <p class="scale-item" style="font-size: 0.72rem; font-weight: 400; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase;">Tag — 11.5px</p>
        </div>
      </div>
    </section>

    <!-- Color Palette -->
    <section class="section-panel section-panel--alt">
      <span class="outline-text outline-text--right" aria-hidden="true">Color</span>
      <div class="section-inner">
        <h2 class="section-title" data-aos="morph-up" data-aos-duration="800">Color Palette from this website</h2>
        <p class="section-subtitle" data-aos="fade-up">
          A restrained palette anchored by black and orange. Every color earns its place — 
          no decoration, only function.
        </p>

        <div class="palette-grid" data-aos="scale-in" data-aos-duration="800">
          <div class="swatch swatch--primary">
            <div class="swatch-color" style="background: #0a0a0a;"></div>
            <div class="swatch-info">
              <span class="swatch-name">Void Black</span>
              <span class="swatch-hex">#0A0A0A</span>
            </div>
          </div>
          <div class="swatch swatch--accent">
            <div class="swatch-color" style="background: #FF7518;"></div>
            <div class="swatch-info">
              <span class="swatch-name">Signal Orange</span>
              <span class="swatch-hex">#FF7518</span>
            </div>
          </div>
          <div class="swatch swatch--light">
            <div class="swatch-color" style="background: #F5F4F0;"></div>
            <div class="swatch-info">
              <span class="swatch-name">Warm White</span>
              <span class="swatch-hex">#F5F4F0</span>
            </div>
          </div>
          <div class="swatch swatch--text">
            <div class="swatch-color" style="background: #333333;"></div>
            <div class="swatch-info">
              <span class="swatch-name">Body Text</span>
              <span class="swatch-hex">#333333</span>
            </div>
          </div>
          <div class="swatch swatch--muted">
            <div class="swatch-color" style="background: #999999;"></div>
            <div class="swatch-info">
              <span class="swatch-name">Secondary</span>
              <span class="swatch-hex">#999999</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Behance CTA -->
    <section class="section-panel brand-cta-section">
      <div class="section-inner brand-cta-inner">
        <div data-aos="morph-up" data-aos-duration="1000">
          <p class="brand-cta-outline">SEE THE<br />FULL PROJECT.</p>
        </div>
        <p class="brand-cta-body" data-aos="fade-up" data-aos-delay="200">
          View the complete personal branding case study with full-resolution mockups, 
          additional logo explorations, and detailed design breakdowns on Behance.
        </p>
        <a
          href="https://www.behance.net/gallery/157368341/Cabizares-Roel-Cezar-Personal-Branding"
          target="_blank"
          rel="noopener noreferrer"
          class="brand-cta-btn"
          data-aos="fade-up"
          data-aos-delay="300"
        >
          View on Behance
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7" /><path d="M7 7h10v10" />
          </svg>
        </a>
      </div>
    </section>

    <!-- Back link -->
    <section class="section-panel">
      <div class="section-inner" style="text-align: center;">
        <a href={base} class="back-link" data-aos="fade-up">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5" /><path d="M12 19l-7-7 7-7" />
          </svg>
          Back to Home
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* Progress bar */
  const progressBar = document.createElement('div');
  progressBar.className = 'scroll-progress';
  document.body.appendChild(progressBar);
  gsap.to(progressBar, {
    scaleX: 1,
    ease: 'none',
    scrollTrigger: {
      trigger: document.documentElement,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.3,
    },
  });

  /* Outline text reveal */
  gsap.utils.toArray<HTMLElement>('.outline-text').forEach((el) => {
    const isRight = el.classList.contains('outline-text--right');
    gsap.fromTo(el,
      { opacity: 0, x: isRight ? 40 : -40 },
      {
        opacity: 1, x: 0, duration: 1, ease: 'power3.out',
        scrollTrigger: { trigger: el.parentElement, start: 'top 85%', toggleActions: 'play none none none' },
      }
    );
  });

  /* Section inner parallax */
  gsap.utils.toArray<HTMLElement>('.section-panel .section-inner').forEach((inner) => {
    gsap.fromTo(inner,
      { y: 40, opacity: 0.8 },
      {
        y: 0, opacity: 1, duration: 1, ease: 'power2.out',
        scrollTrigger: { trigger: inner.parentElement, start: 'top 90%', end: 'top 40%', scrub: 0.5 },
      }
    );
  });

  /* Logo showcase stagger */
  const logos = gsap.utils.toArray<HTMLElement>('.logo-display');
  if (logos.length) {
    gsap.set(logos, { opacity: 0, y: 60, scale: 0.95 });
    ScrollTrigger.create({
      trigger: '.logo-showcase',
      start: 'top 80%',
      onEnter: () => {
        gsap.to(logos, { opacity: 1, y: 0, scale: 1, duration: 0.8, stagger: 0.2, ease: 'power3.out' });
      },
      once: true,
    });
  }

  /* Principles stagger */
  const principles = gsap.utils.toArray<HTMLElement>('.principle');
  if (principles.length) {
    gsap.set(principles, { opacity: 0, y: 40 });
    ScrollTrigger.create({
      trigger: '.logo-principles',
      start: 'top 82%',
      onEnter: () => {
        gsap.to(principles, { opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power2.out' });
      },
      once: true,
    });
  }

  /* Swatches pop-in */
  const swatches = gsap.utils.toArray<HTMLElement>('.swatch');
  if (swatches.length) {
    gsap.set(swatches, { opacity: 0, scale: 0.8, y: 30 });
    ScrollTrigger.create({
      trigger: '.palette-grid',
      start: 'top 80%',
      onEnter: () => {
        gsap.to(swatches, { opacity: 1, scale: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'back.out(1.6)' });
      },
      once: true,
    });
  }

  /* Brand CTA zoom reveal */
  const ctaOutline = document.querySelector('.brand-cta-outline') as HTMLElement | null;
  if (ctaOutline) {
    gsap.fromTo(ctaOutline,
      { scale: 1.3, filter: 'blur(6px)', opacity: 0 },
      {
        scale: 1, filter: 'blur(0px)', opacity: 1, ease: 'none',
        scrollTrigger: { trigger: '.brand-cta-section', start: 'top 78%', end: 'center center', scrub: 0.8 },
      }
    );
  }

  /* Floating orbs */
  const orbConfigs = [
    { sel: '.brand-hero', size: 200, pos: 'right: 10%; top: 25%', dx: 25, dy: -50 },
    { sel: '.brand-hero', size: 140, pos: 'left: 8%; bottom: 30%', dx: -20, dy: -35 },
    { sel: '.brand-cta-section', size: 180, pos: 'left: 15%; top: 30%', dx: -15, dy: -40 },
  ];
  orbConfigs.forEach(({ sel, size, pos, dx, dy }) => {
    const parent = document.querySelector(sel) as HTMLElement | null;
    if (!parent) return;
    const orb = document.createElement('div');
    orb.className = 'floating-orb-decor';
    orb.style.cssText = `
      position: absolute; width: ${size}px; height: ${size}px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--color-orange-glow), transparent 70%);
      pointer-events: none; z-index: 0;
      filter: blur(50px); opacity: 0.3;
      ${pos}
    `;
    parent.appendChild(orb);
    gsap.to(orb, {
      y: dy, x: dx, ease: 'none',
      scrollTrigger: { trigger: parent, start: 'top bottom', end: 'bottom top', scrub: 1.5 },
    });
  });
</script>

<style>
  /* ── Brand Hero ── */
  .brand-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: clamp(6rem, 12vw, 10rem) clamp(1.25rem, 5vw, 7.2%) clamp(4rem, 8vw, 7rem);
  }

  .brand-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-shape-brand {
    position: absolute;
    top: 50%;
    right: 10%;
    width: 420px;
    height: 420px;
    transform: translateY(-50%);
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    background: var(--hero-shape-bg);
    backdrop-filter: blur(60px);
    -webkit-backdrop-filter: blur(60px);
    border: 1px solid var(--border);
    animation: morphShape 12s ease-in-out infinite, float 6s ease-in-out infinite;
  }

  .brand-hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .brand-label {
    font-size: var(--fs-2xs);
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 1.5rem;
  }

  .brand-title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .brand-desc {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 56ch;
    margin-bottom: 2rem;
  }

  .brand-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .meta-tag {
    font-size: var(--fs-2xs);
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 2rem;
    color: var(--text-muted);
  }

  /* ── Overview ── */
  .brand-overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .overview-block h3 {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .overview-block p {
    font-size: var(--fs-base);
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .overview-block p strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .tools-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .tool-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--fs-base);
    color: var(--text-secondary);
  }

  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 0.75rem;
    background: var(--glass-bg);
    border: 1px solid var(--border);
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--color-orange);
    letter-spacing: -0.5px;
  }

  /* ── Section subtitle ── */
  .section-subtitle {
    font-size: var(--fs-base);
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 60ch;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  /* ── C.A.B.Z Logo Meaning ── */
  .cabz-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .cabz-letter {
    padding: 2rem 1.5rem;
    border-radius: 1rem;
    border: 1px solid var(--border);
    background: var(--glass-bg);
    text-align: center;
    transition: border-color 0.3s, transform 0.3s;
  }

  .cabz-letter:hover {
    border-color: var(--color-orange-dim);
    transform: translateY(-4px);
  }

  .cabz-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 1rem;
    user-select: none;
  }

  .cabz-tag {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--text-muted);
    line-height: 1;
    opacity: 0.4;
  }

  .cabz-char {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    line-height: 1;
  }

  .cabz-tag--slash {
    color: var(--text-primary);
    opacity: 0.8;
    margin: 0 -0.1em;
  }

  .cabz-letter h3 {
    font-size: var(--fs-lg);
