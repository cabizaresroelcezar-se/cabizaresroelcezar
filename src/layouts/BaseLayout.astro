---
import '../styles/style.css';
import '../styles/globals.css';
import '../styles/spatial.css';
import '../styles/cabzcbzrs.css';
import 'aos/dist/aos.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = 'Roel Cezar Cabizares - Software Engineer, Front-end Developer, UI/UX Enthusiast', 
  description = 'Software engineer specializing in front-end development, UI/UX, and creating intuitive, dynamic user experiences. Based in the Philippines.',
  image = '/og-image.jpg' 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark light" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/manrope-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/manrope-300.woff2" as="font" type="font/woff2" crossorigin />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cabizaresroelcezar.github.io" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://cabizaresroelcezar.github.io" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.png" />
    
    <!-- DNS Prefetch -->
    <link rel="dns-prefetch" href="//www.googletagmanager.com" />
    
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-M3KQ45N');
    </script>

    <title>{title}</title>

    <!-- Theme: restore preference before paint -->
    <script is:inline>
      (function(){
        var t;
        try { t = localStorage.getItem('theme'); } catch(e) {}
        document.documentElement.setAttribute('data-theme', t || 'dark');
      })();
    </script>

    <!-- Block developer tools -->
    <script is:inline>
      (function(){
        /* Disable right-click context menu */
        document.addEventListener('contextmenu', function(e) { e.preventDefault(); });

        /* Block common devtools keyboard shortcuts */
        document.addEventListener('keydown', function(e) {
          /* F12 */
          if (e.key === 'F12') { e.preventDefault(); return; }
          /* Ctrl/Cmd + Shift + I (Inspector) */
          if ((e.ctrlKey || e.metaKey) && e.shiftKey && (e.key === 'I' || e.key === 'i')) { e.preventDefault(); return; }
          /* Ctrl/Cmd + Shift + J (Console) */
          if ((e.ctrlKey || e.metaKey) && e.shiftKey && (e.key === 'J' || e.key === 'j')) { e.preventDefault(); return; }
          /* Ctrl/Cmd + Shift + C (Element picker) */
          if ((e.ctrlKey || e.metaKey) && e.shiftKey && (e.key === 'C' || e.key === 'c')) { e.preventDefault(); return; }
          /* Ctrl/Cmd + U (View source) */
          if ((e.ctrlKey || e.metaKey) && !e.shiftKey && (e.key === 'U' || e.key === 'u')) { e.preventDefault(); return; }
        });
      })();
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M3KQ45N" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <div class="wrapper">
      <slot />
    </div>

    <!-- Cursor ambient glow -->
    <div class="cursor-glow" id="cursor-glow" aria-hidden="true"></div>

    <!-- AOS Script -->
    <script>
      import AOS from 'aos';
      AOS.init({
        duration: 600,
        easing: 'ease-out-cubic',
        once: true,
      });
    </script>

    <!-- Cursor glow tracker -->
    <script>
      const cursorGlow = document.getElementById('cursor-glow');
      if (cursorGlow && window.matchMedia('(pointer: fine)').matches) {
        let gRaf: number | null = null;
        document.addEventListener('mousemove', (e: MouseEvent) => {
          if (gRaf) return;
          gRaf = requestAnimationFrame(() => {
            cursorGlow.style.left = e.clientX + 'px';
            cursorGlow.style.top = e.clientY + 'px';
            gRaf = null;
          });
        });
      }
    </script>
  </body>
</html>
